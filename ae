#!/usr/bin/env bash
# ae - agentic engineering: tmux-based multi-agent workspace
set -euo pipefail

CONFIG_DIR="${HOME}/.ae"
CONFIG_FILE="${CONFIG_DIR}/config"
WORKTREES_DIR="${CONFIG_DIR}/worktrees"
SESSIONS_DIR="${CONFIG_DIR}/sessions"

# Per-project config override (optional)
AE_LOCAL_CONFIG=""
[[ -f ".ae/config" ]] && AE_LOCAL_CONFIG="$(pwd)/.ae/config"

# Optional: isolated tmux server (for testing or multi-instance use)
if [[ -n "${AE_TMUX_SERVER:-}" ]]; then
    tmux() { command tmux -L "$AE_TMUX_SERVER" "$@"; }
fi

# --- Function index ---
#   Config:     parse_config, get_config
#   Helpers:    tool_name_from_cmd, tool_kind_from_cmd, default_session_name, tmux_attach, gen_uuid, detect_current_session
#   Resume:     strip_session_flags, resume_cmd_from_cmd, inject_session_id, inject_ae_context, resolve_agent_session_id
#   Session:    read_session_meta, list_ae_sessions, iter_stopped_sessions, cleanup_session
#   End/branch: sanitize_branch_name, resolve_session_workdir, end_session
#   Commands:   cmd_list, cmd_status, cmd_end, cmd_discard, cmd_help, _cmd_spawn
#   Manifest:   regenerate_manifest
#   Launch:     send_agent_cmd, capture_codex_session_id

DEFAULT_CONFIG='[agents]
claude = "claude --permission-mode bypassPermissions --model claude-opus-4-6"
codex = "codex --yolo -m gpt-5.3-codex -c model_reasoning_effort=high"
opencode = "opencode"

[workspace]
main = claude
layout = vertical'

# Create default config if missing
if [[ ! -f "$CONFIG_FILE" ]]; then
    mkdir -p "$CONFIG_DIR"
    printf '%s\n' "$DEFAULT_CONFIG" > "$CONFIG_FILE"
    echo "Created default config at $CONFIG_FILE"
fi

# Simple INI parser — outputs section.key=value lines
# Reads global config, then per-project .ae/config (local values shadow global)
parse_config() {
    local section="" file
    for file in "$CONFIG_FILE" "${AE_LOCAL_CONFIG:-}"; do
        [[ -n "$file" ]] && [[ -f "$file" ]] || continue
        section=""
        while IFS= read -r line; do
            line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
            [[ -z "$line" ]] && continue

            if [[ "$line" =~ ^\[([a-zA-Z_]+)\]$ ]]; then
                section="${BASH_REMATCH[1]}"
                continue
            fi

            # Strip comments only outside quoted values
            if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)\ *=\ *\"(.*)\"$ ]]; then
                printf '%s\n' "${section}.${BASH_REMATCH[1]}=${BASH_REMATCH[2]}"
            elif [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)\ *=\ *(.+)$ ]]; then
                local val="${BASH_REMATCH[2]}"
                val="${val%%#*}"
                val="$(echo "$val" | sed 's/[[:space:]]*$//')"
                printf '%s\n' "${section}.${BASH_REMATCH[1]}=${val}"
            else
                continue
            fi
        done < "$file"
    done
}

# Last match wins — local config overrides global
get_config() {
    local result=""
    while IFS= read -r entry; do
        if [[ "$entry" == "${1}="* ]]; then
            result="${entry#*=}"
        fi
    done < <(parse_config)
    printf '%s' "$result"
}

# Map command prefix to human-readable tool name
tool_name_from_cmd() {
    case "$1" in
        claude*) echo "claude code" ;;
        codex*)  echo "codex" ;;
        opencode*) echo "opencode" ;;
        *)       echo "$1" ;;
    esac
}

# Strip session/resume flags from a command (whole-token matching to avoid mangling e.g. --continue-on-error)
strip_session_flags() {
    echo "$1" | sed \
        -e 's/\(^\|  *\)--session-id[= ][^ ]*/\1/g' \
        -e 's/\(^\|  *\)--resume[= ][^ ]*/\1/g' \
        -e 's/\(^\|  *\)--continue\(  *\|$\)/\1\2/g' \
        -e 's/  */ /g; s/^ //; s/ $//'
}

# Derive resume command with session-scoped ID (survives multiple concurrent sessions)
# Falls back to heuristic resume, then fresh start
resume_cmd_from_cmd() {
    local cmd="$1" session_id="${2:-}"
    # Treat "pending" (uncaptured) as no session ID — fall back to fresh start
    [[ "$session_id" == "pending" ]] && session_id=""
    local clean
    clean="$(strip_session_flags "$cmd")"
    case "$cmd" in
        claude*)
            if [[ -n "$session_id" ]]; then
                echo "${clean} --resume ${session_id}"
            else
                echo "${clean} --continue"
            fi
            ;;
        codex*)
            if [[ -n "$session_id" ]]; then
                echo "codex resume ${session_id}"
            else
                echo "$clean"  # fresh start (--last is unreliable for concurrent sessions)
            fi
            ;;
        *)  echo "$clean" ;;  # fresh start for unknown agents
    esac
}

# Inject agent-scoped session ID into start command (enables targeted resume later)
inject_session_id() {
    local cmd="$1" session_id="$2"
    [[ "$session_id" == "pending" ]] && session_id=""
    local clean
    clean="$(strip_session_flags "$cmd")"
    if [[ -n "$session_id" ]]; then
        case "$cmd" in
            claude*) echo "${clean} --session-id ${session_id}" ;;
            *)       echo "$clean" ;;
        esac
    else
        echo "$clean"
    fi
}

# Inject ae workspace context into agent system prompt (survives context compaction)
# Claude Code: --append-system-prompt; Codex: -c developer_instructions; others: no-op
inject_ae_context() {
    local cmd="$1" meta_dir="$2" session="${3:-}" work_dir="${4:-}"
    local ctx="You are in an ae multi-agent workspace. Session: ${session}. Directory: ${work_dir}. Spawn another agent: ${meta_dir}/spawn <alias> [prompt]. Send a message: ${meta_dir}/send \"<pane_id>\" \"<message>\". Check another agent: tmux capture-pane -t \"<pane_id>\" -p | tail -20. Current agent layout and pane IDs: cat ${meta_dir}/workspace.md. Pane IDs look like %0, %1, etc."
    local escaped="${ctx//\'/\'\\\'\'}"
    case "$cmd" in
        claude*)
            echo "${cmd} --append-system-prompt '${escaped}'"
            ;;
        codex*)
            echo "${cmd} -c developer_instructions='${escaped}'"
            ;;
        *) echo "$cmd" ;;
    esac
}

# Generate a UUID (for agent session scoping)
gen_uuid() {
    if [[ -f /proc/sys/kernel/random/uuid ]]; then
        cat /proc/sys/kernel/random/uuid
    elif command -v uuidgen >/dev/null 2>&1; then
        uuidgen
    else
        echo "ae: no UUID generator available (need /proc/sys/kernel/random/uuid or uuidgen)" >&2
        echo "ae: install util-linux or uuid-runtime, or ensure /proc is mounted" >&2
        return 1
    fi
}

# Detect current ae session when running inside tmux (for ae end/discard/status without name)
detect_current_session() {
    if [[ -n "${TMUX:-}" ]]; then
        local session_name
        session_name="$(tmux display-message -p '#{session_name}' 2>/dev/null)" || return 1
        if [[ -d "${SESSIONS_DIR}/${session_name}" ]]; then
            echo "$session_name"
            return 0
        fi
    fi
    return 1
}

# Detect tool kind from command (for staleness checks on resume)
tool_kind_from_cmd() {
    case "$1" in
        claude*)   echo "claude" ;;
        codex*)    echo "codex" ;;
        opencode*) echo "opencode" ;;
        *)         echo "unknown" ;;
    esac
}

# Best-effort: capture Codex session ID post-launch (codex prints "session id: <uuid>" on startup)
capture_codex_session_id() {
    local pane="$1" slot="$2" meta_dir="$3"
    sleep 5
    local captured
    captured="$(tmux capture-pane -t "$pane" -p 2>/dev/null | grep -oP 'session id: \K[0-9a-f-]+' | head -1 || true)"
    if [[ -n "$captured" ]]; then
        (
            flock -w 5 200 || exit 1
            local escaped_slot="${slot//./\\.}"
            sed -i "s/^agent_session\.${escaped_slot}=codex:.*$/agent_session.${slot}=codex:${captured}/" "$meta_dir/meta"
        ) 200>"$meta_dir/meta.lock"
    fi
}

# Generate or restore a session-scoped agent ID
# Uses globals $RESUMING and $SESSION when available (main launch path)
# For _cmd_spawn: RESUMING is unset → always generates new IDs
resolve_agent_session_id() {
    local cmd="$1" slot="$2"
    local kind
    kind="$(tool_kind_from_cmd "$cmd")"
    local session_id=""
    if [[ "${RESUMING:-}" == true ]] && [[ -n "${SESSION:-}" ]]; then
        local stored
        stored="$(read_session_meta "$SESSION" "agent_session.${slot}")"
        if [[ -n "$stored" ]]; then
            local stored_kind="${stored%%:*}"
            local stored_id="${stored#*:}"
            if [[ "$stored_kind" == "$kind" ]] && [[ "$stored_id" != "pending" ]]; then
                session_id="$stored_id"
            fi
        fi
    fi
    if [[ -z "$session_id" ]]; then
        case "$cmd" in
            claude*) session_id="$(gen_uuid)" ;;
            *)       session_id="pending" ;;
        esac
    fi
    echo "$session_id"
}

# Derive default session name from PWD
default_session_name() {
    local dir="${PWD/#$HOME\//}"
    local hash
    hash="$(printf '%s' "$PWD" | md5sum | cut -c1-6)"
    dir="${dir//\//-}"
    dir="${dir//./_}"
    echo "ae-${dir}-${hash}"
}

# Attach or switch to a tmux session (handles being inside tmux already)
tmux_attach() {
    local target="$1"
    if [[ -n "${TMUX:-}" ]]; then
        exec tmux switch-client -t "$target"
    else
        exec tmux attach-session -t "$target"
    fi
}

# Read a session's metadata file (mode, origin)
read_session_meta() {
    local session_name="$1" key="$2"
    local meta="${SESSIONS_DIR}/${session_name}/meta"
    # Backward compat: try old worktree-nested path
    if [[ ! -f "$meta" ]]; then
        meta="${WORKTREES_DIR}/${session_name}/.ae/${session_name}/meta"
    fi
    if [[ -f "$meta" ]]; then
        while IFS='=' read -r k v; do
            if [[ "$k" == "$key" ]]; then
                printf '%s' "$v"
                return
            fi
        done < "$meta"
    fi
}

# List all ae sessions (tagged with AE_SESSION env var)
list_ae_sessions() {
    local sessions=""
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if tmux show-environment -t "$name" AE_SESSION 2>/dev/null | grep -q '^AE_SESSION='; then
            sessions="${sessions}${name}\n"
        fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
    printf '%b' "$sessions"
}

# Iterate stopped sessions (on disk but not running), de-duplicated across SESSIONS_DIR and WORKTREES_DIR
iter_stopped_sessions() {
    declare -A _seen=()
    for dir in "$SESSIONS_DIR" "$WORKTREES_DIR"; do
        [[ -d "$dir" ]] || continue
        for entry in "$dir"/*/; do
            [[ -d "$entry" ]] || continue
            local name
            name="$(basename "$entry")"
            [[ -n "${_seen[$name]:-}" ]] && continue
            tmux has-session -t "$name" 2>/dev/null && continue
            _seen[$name]=1
            echo "$name"
        done
    done
}

# Clean up session resources (mode-aware)
cleanup_session() {
    local session_name="$1"
    local wt="${WORKTREES_DIR}/${session_name}"

    # Read mode and origin from tmux env (running sessions) then on-disk meta (stopped)
    local mode origin
    mode="$(tmux show-environment -t "$session_name" AE_MODE 2>/dev/null | sed 's/^AE_MODE=//' || true)"
    origin="$(tmux show-environment -t "$session_name" AE_ORIGIN 2>/dev/null | sed 's/^AE_ORIGIN=//' || true)"
    if [[ -z "$mode" ]]; then
        mode="$(read_session_meta "$session_name" mode)"
    fi
    if [[ -z "$origin" ]]; then
        origin="$(read_session_meta "$session_name" origin)"
    fi

    # Always clean session state from SESSIONS_DIR
    rm -rf "${SESSIONS_DIR}/${session_name}"
    # Legacy cleanup: old worktree-nested and local-mode paths
    rm -rf "${WORKTREES_DIR}/${session_name}/.ae/${session_name}" 2>/dev/null || true
    if [[ -n "$origin" ]] && [[ -d "${origin}/.ae/${session_name}" ]]; then
        rm -rf "${origin}/.ae/${session_name}"
    fi

    if [[ "$mode" == "local" ]]; then
        echo "Cleaned up local session $session_name"
        return 0
    fi

    [[ -d "$wt" ]] || return 0

    if [[ "$mode" == "git" ]] && [[ -n "$origin" ]]; then
        git -C "$origin" worktree remove --force "$wt" 2>/dev/null || rm -rf "$wt"
        git -C "$origin" worktree prune 2>/dev/null || true
    else
        rm -rf "$wt"
    fi
    echo "Removed worktree for $session_name"
}

# Sanitize session name to valid git branch name
sanitize_branch_name() {
    local name="$1"
    # Strip ae- prefix for cleaner branch names
    name="${name#ae-}"
    # Replace invalid chars with -, collapse repeats, trim edges
    name="$(echo "$name" | sed 's/[^a-zA-Z0-9._-]/-/g; s/--*/-/g; s/^-//; s/-$//')"
    echo "ae/${name}"
}

# Resolve work directory for a session (running or stopped)
resolve_session_workdir() {
    local session_name="$1"
    local wdir=""
    # Try tmux env first (running session)
    wdir="$(tmux show-environment -t "$session_name" AE_DIR 2>/dev/null | sed 's/^AE_DIR=//' || true)"
    if [[ -z "$wdir" ]] || [[ ! -d "$wdir" ]]; then
        # Try on-disk meta (stopped session)
        wdir="$(read_session_meta "$session_name" work_dir)"
    fi
    if [[ -z "$wdir" ]] || [[ ! -d "$wdir" ]]; then
        # Fallback: standard worktree path
        wdir="${WORKTREES_DIR}/${session_name}"
    fi
    echo "$wdir"
}

# End a session: commit dirty state, push to ae/<branch>, then clean up
# Returns non-zero on failure (session is preserved on failure)
end_session() {
    local session_name="$1"

    # Resolve mode and origin
    local mode origin wdir
    mode="$(tmux show-environment -t "$session_name" AE_MODE 2>/dev/null | sed 's/^AE_MODE=//' || true)"
    origin="$(tmux show-environment -t "$session_name" AE_ORIGIN 2>/dev/null | sed 's/^AE_ORIGIN=//' || true)"
    if [[ -z "$mode" ]]; then
        mode="$(read_session_meta "$session_name" mode)"
    fi
    if [[ -z "$origin" ]]; then
        origin="$(read_session_meta "$session_name" origin)"
    fi
    wdir="$(resolve_session_workdir "$session_name")"

    # Local mode: just clean up (no work to preserve — files are in original dir)
    if [[ "$mode" == "local" ]]; then
        if tmux has-session -t "$session_name" 2>/dev/null; then
            tmux kill-session -t "$session_name"
        fi
        cleanup_session "$session_name"
        echo "Ended local session $session_name"
        return 0
    fi

    # git/full mode: commit + push if in a git repo
    if [[ -d "$wdir" ]] && git -C "$wdir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        # Check for uncommitted changes
        if ! git -C "$wdir" diff --quiet 2>/dev/null || ! git -C "$wdir" diff --cached --quiet 2>/dev/null || \
           [[ -n "$(git -C "$wdir" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
            echo "Committing changes in $session_name..."
            git -C "$wdir" add -A
            local ts
            ts="$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
            if ! git -C "$wdir" commit -m "ae: end session ${session_name}" -m "Ended: ${ts}"; then
                echo "Error: commit failed. Session preserved — fix manually and retry." >&2
                echo "  Working directory: $wdir" >&2
                return 1
            fi
        fi

        # Check if there's anything to push (HEAD not already on a remote branch)
        local needs_push=false
        if git -C "$wdir" remote get-url origin >/dev/null 2>&1; then
            # Fetch silently to check against remote state
            git -C "$wdir" fetch origin --quiet 2>/dev/null || true
            if ! git -C "$wdir" branch -r --contains HEAD 2>/dev/null | grep -q .; then
                needs_push=true
            fi
        fi

        if [[ "$needs_push" == true ]]; then
            local branch
            branch="$(sanitize_branch_name "$session_name")"
            echo "Pushing to origin/${branch}..."

            # Show what we're pushing (count files changed across all unpushed commits)
            local file_count
            file_count="$(git -C "$wdir" diff --name-only "$(git -C "$wdir" merge-base HEAD origin/HEAD 2>/dev/null || echo HEAD~1)" HEAD 2>/dev/null | wc -l || echo "?")"
            echo "  ${file_count} file(s) changed"

            if ! git -C "$wdir" push -u origin "HEAD:refs/heads/${branch}"; then
                echo "Error: push failed. Session preserved — fix manually and retry." >&2
                echo "  Working directory: $wdir" >&2
                echo "  To retry: cd $wdir && git push -u origin HEAD:refs/heads/${branch}" >&2
                return 1
            fi
            echo "Pushed to origin/${branch}"
        else
            if ! git -C "$wdir" remote get-url origin >/dev/null 2>&1; then
                echo "No remote 'origin' — skipping push."
            else
                echo "No new commits to push."
            fi
        fi
    else
        echo "Error: working directory is not a git repo — cannot preserve work." >&2
        echo "  Use 'ae discard $session_name' to destroy without saving." >&2
        return 1
    fi

    # All good — clean up
    if tmux has-session -t "$session_name" 2>/dev/null; then
        tmux kill-session -t "$session_name"
    fi
    cleanup_session "$session_name"
    echo "Ended $session_name"
    return 0
}

# --- Subcommands ---

cmd_list() {
    local sessions has_output=false
    local hdr='%-40s  %-10s  %-8s  %-5s  %s\n'
    sessions="$(list_ae_sessions)"
    if [[ -n "$sessions" ]]; then
        has_output=true
        printf "$hdr" "SESSION" "STATUS" "AGENTS" "MODE" "ORIGIN"
        while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            local total=0 alive=0 origin mode health
            while IFS=$'\t' read -r pane_title pane_cmd; do
                [[ "$pane_title" == ae:* ]] || continue
                total=$(( total + 1 ))
                case "$pane_cmd" in
                    bash|fish|zsh|sh|dash) ;;
                    *) alive=$(( alive + 1 )) ;;
                esac
            done < <(tmux list-panes -t "$name" -F '#{pane_title}	#{pane_current_command}' 2>/dev/null)
            health="${alive}/${total}"
            [[ $alive -lt $total ]] && health="${health}!"
            origin="$(tmux show-environment -t "$name" AE_ORIGIN 2>/dev/null | sed 's/^AE_ORIGIN=//' || echo "?")"
            mode="$(tmux show-environment -t "$name" AE_MODE 2>/dev/null | sed 's/^AE_MODE=//' || true)"
            mode="${mode:-$(read_session_meta "$name" mode)}"
            mode="${mode:-?}"
            printf "$hdr" "$name" "running" "$health" "$mode" "$origin"
        done <<< "$sessions"
    fi
    while IFS= read -r name; do
        if [[ "$has_output" == false ]]; then
            printf "$hdr" "SESSION" "STATUS" "AGENTS" "MODE" "ORIGIN"
            has_output=true
        fi
        local mode origin
        mode="$(read_session_meta "$name" mode)"
        mode="${mode:-?}"
        origin="$(read_session_meta "$name" origin)"
        origin="${origin:--}"
        printf "$hdr" "$name" "stopped" "-" "$mode" "$origin"
    done < <(iter_stopped_sessions)
    if [[ "$has_output" == false ]]; then
        echo "No ae sessions."
    fi
}

cmd_status() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        target="$(detect_current_session 2>/dev/null)" || {
            echo "Usage: ae status [session-name]" >&2
            echo "(Run inside an ae tmux session to check status without specifying the name.)" >&2
            return 1
        }
    fi
    if ! tmux has-session -t "$target" 2>/dev/null; then
        if [[ -d "${SESSIONS_DIR}/${target}" ]]; then
            echo "Session '$target' is stopped."
            return 0
        fi
        echo "Session '$target' not found." >&2
        return 1
    fi
    local found=false
    while IFS=$'\t' read -r pane_id pane_title; do
        [[ "$pane_title" == ae:* ]] || continue
        found=true
        echo "── ${pane_title} (${pane_id}) ──"
        tmux capture-pane -t "$pane_id" -p 2>/dev/null | grep -v '^$' | tail -15
        echo ""
    done < <(tmux list-panes -t "$target" -F '#{pane_id}	#{pane_title}' 2>/dev/null)
    if [[ "$found" == false ]]; then
        echo "No agent panes in session '$target'."
    fi
}

cmd_end() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        target="$(detect_current_session 2>/dev/null)" || {
            echo "Usage: ae end [session-name]" >&2
            echo "       ae end all" >&2
            echo "(Run inside an ae tmux session to end it without specifying the name.)" >&2
            return 1
        }
    fi
    if [[ "$target" == "all" ]]; then
        local found=false failures=0
        local sessions
        sessions="$(list_ae_sessions)"
        if [[ -n "$sessions" ]]; then
            while IFS= read -r s; do
                [[ -z "$s" ]] && continue
                found=true
                end_session "$s" || failures=$(( failures + 1 ))
            done <<< "$sessions"
        fi
        while IFS= read -r name; do
            found=true
            end_session "$name" || failures=$(( failures + 1 ))
        done < <(iter_stopped_sessions)
        if [[ "$found" == false ]]; then
            echo "No ae sessions."
        elif (( failures > 0 )); then
            echo "${failures} session(s) failed to end. See errors above." >&2
            return 1
        fi
    else
        if tmux has-session -t "$target" 2>/dev/null; then
            end_session "$target" || return 1
        elif [[ ! "$target" =~ [/] ]] && [[ -d "${SESSIONS_DIR}/${target}" ]]; then
            end_session "$target" || return 1
        elif [[ ! "$target" =~ [/] ]] && [[ -d "${WORKTREES_DIR}/${target}" ]]; then
            end_session "$target" || return 1
        else
            echo "Session '$target' not found." >&2
            return 1
        fi
    fi
}

cmd_discard() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        target="$(detect_current_session 2>/dev/null)" || {
            echo "Usage: ae discard [session-name]" >&2
            echo "       ae discard all" >&2
            echo "(Run inside an ae tmux session to discard it without specifying the name.)" >&2
            return 1
        }
    fi
    if [[ "$target" == "all" ]]; then
        local found=false
        local sessions
        sessions="$(list_ae_sessions)"
        if [[ -n "$sessions" ]]; then
            while IFS= read -r s; do
                [[ -z "$s" ]] && continue
                found=true
                cleanup_session "$s"
                tmux kill-session -t "$s"
                echo "Discarded $s"
            done <<< "$sessions"
        fi
        while IFS= read -r name; do
            found=true
            cleanup_session "$name"
            echo "Discarded stopped session $name"
        done < <(iter_stopped_sessions)
        if [[ "$found" == false ]]; then
            echo "No ae sessions."
        fi
    else
        if tmux has-session -t "$target" 2>/dev/null; then
            cleanup_session "$target"
            tmux kill-session -t "$target"
            echo "Discarded $target"
        elif [[ ! "$target" =~ [/] ]] && [[ -d "${SESSIONS_DIR}/${target}" ]]; then
            cleanup_session "$target"
            echo "Discarded stopped session $target"
        elif [[ ! "$target" =~ [/] ]] && [[ -d "${WORKTREES_DIR}/${target}" ]]; then
            cleanup_session "$target"
            echo "Discarded stopped session $target"
        else
            echo "Session '$target' not found." >&2
            return 1
        fi
    fi
}

cmd_help() {
    echo "ae - agentic engineering: tmux multi-agent workspace"
    echo ""
    echo "Usage:"
    echo "  ae                     Start or reattach default session (local)"
    echo "  ae <name>              Start or reattach a named session"
    echo "  ae --local [name]      Start session in current directory (default)"
    echo "  ae --copy [name]       Start session with full copy (includes untracked files)"
    echo "  ae --worktree [name]   Start session with git worktree (tracked files only)"
    echo "  ae list                List all ae sessions"
    echo "  ae status [name]       Show recent agent output without attaching"
    echo "  ae end [name]          End a session: commit, push, clean up (or 'ae end all')"
    echo "  ae discard [name]      Discard a session without saving (or 'ae discard all')"
    echo "  ae help                Show this help"
    echo ""
    echo "Modes: --local (default), --copy (full cp -a), --worktree (git worktree)."
    echo "Sessions persist across reboots. Agents with session support resume conversations; others start fresh."
    echo "When inside an ae session, end/discard/status work without specifying the name."
    echo ""
    echo "Config: ~/.ae/config (per-project override: .ae/config in project dir)"
}

# Internal: spawn a new agent pane (called via spawn helper → ae _spawn)
_cmd_spawn() {
    local meta_dir="$1"; shift
    local alias_name="$1"; shift
    local prompt="${*:-"You were spawned into an ae workspace. Read ${meta_dir}/workspace.md for details."}"

    # Read meta
    declare -A meta=()
    while IFS='=' read -r k v; do
        case "$k" in
            mode|origin|session|work_dir|layout|config|main_pane) meta["$k"]="$v" ;;
        esac
    done < "$meta_dir/meta"

    local session="${meta[session]:-}" work_dir="${meta[work_dir]:-}" layout="${meta[layout]:-vertical}"
    local config_file="${meta[config]:-}" main_pane="${meta[main_pane]:-}"
    local origin="${meta[origin]:-}" mode="${meta[mode]:-}"

    if [[ -z "$session" ]]; then
        echo "Error: session not found in metadata" >&2; return 1
    fi
    if ! tmux has-session -t "$session" 2>/dev/null; then
        echo "Error: session '$session' not running" >&2; return 1
    fi

    CONFIG_FILE="$config_file"
    # Wire up per-project config from session's origin directory
    AE_LOCAL_CONFIG=""
    if [[ -n "$origin" ]] && [[ -f "${origin}/.ae/config" ]]; then
        AE_LOCAL_CONFIG="${origin}/.ae/config"
    fi
    local cmd
    cmd="$(get_config "agents.${alias_name}")"
    if [[ -z "$cmd" ]]; then
        echo "Error: agent '${alias_name}' not defined in $config_file" >&2; return 1
    fi

    # Split pane
    local pane_id
    if [[ "$layout" == "vertical" ]]; then
        pane_id="$(tmux split-window -h -t "$session" -c "$work_dir" -P -F '#{pane_id}')"
    else
        pane_id="$(tmux split-window -v -t "$session" -c "$work_dir" -P -F '#{pane_id}')"
    fi

    # Label and rebalance
    tmux select-pane -t "$pane_id" -T "ae:${alias_name}"
    if [[ "$layout" == "vertical" ]]; then
        tmux select-layout -t "$session" even-horizontal
    else
        tmux select-layout -t "$session" even-vertical
    fi

    # Register spawned agent in meta with session ID (survives reboot)
    local next_idx=0
    while [[ -n "$(read_session_meta "$session" "spawned.${next_idx}")" ]]; do
        next_idx=$(( next_idx + 1 ))
    done
    local slot="spawned.${next_idx}"
    local session_id
    session_id="$(resolve_agent_session_id "$cmd" "$slot")"
    local tool_kind
    tool_kind="$(tool_kind_from_cmd "$cmd")"
    (
        flock -w 5 200 || exit 1
        echo "spawned.${next_idx}=${alias_name}" >> "$meta_dir/meta"
        echo "agent_session.${slot}=${tool_kind}:${session_id}" >> "$meta_dir/meta"
    ) 200>"$meta_dir/meta.lock"

    # Regenerate workspace.md from live panes
    regenerate_manifest "$session" "$work_dir" "$origin" "$mode" "$main_pane" "$meta_dir"

    # Launch agent with session-scoped ID and ae workspace context
    local scoped_cmd
    scoped_cmd="$(inject_session_id "$cmd" "$session_id")"
    scoped_cmd="$(inject_ae_context "$scoped_cmd" "$meta_dir" "$session" "$work_dir")"
    tmux send-keys -t "$pane_id" "$scoped_cmd" C-m

    # Post-launch: capture codex session ID if needed
    if [[ "$tool_kind" == "codex" ]]; then
        capture_codex_session_id "$pane_id" "$slot" "$meta_dir" &
    fi

    # Inject prompt via buffer paste (safe for any content)
    sleep 1
    local buf="ae-spawn-$$"
    tmux select-pane -t "$pane_id"
    tmux set-buffer -b "$buf" -- "$prompt"
    tmux paste-buffer -d -b "$buf" -t "$pane_id"
    sleep 0.1
    tmux send-keys -t "$pane_id" Enter

    echo "Spawned $alias_name in pane $pane_id"
}

# --- Dispatcher ---
case "${1:-}" in
    list|ls)        cmd_list; exit 0 ;;
    status)         cmd_status "${2:-}"; exit $? ;;
    end)            cmd_end "${2:-}"; exit $? ;;
    discard)        cmd_discard "${2:-}"; exit $? ;;
    _spawn)         _cmd_spawn "${@:2}"; exit $? ;;
    kill|rm)
        echo "Warning: 'ae kill' is deprecated, use 'ae end' (preserve work) or 'ae discard' (destroy)." >&2
        exec "$0" discard "${2:-}"
        ;;
    help|-h|--help) cmd_help; exit 0 ;;
esac

# --- Parse flags ---
COPY_MODE_OVERRIDE=""
SESSION=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --worktree) COPY_MODE_OVERRIDE="git"; shift ;;
        --copy)     COPY_MODE_OVERRIDE="full"; shift ;;
        --local)    COPY_MODE_OVERRIDE="local"; shift ;;
        --*)    echo "Error: unknown flag '$1'. Use --worktree, --copy, or --local." >&2; exit 1 ;;
        *)      SESSION="$1"; shift ;;
    esac
done

# Session name: use argument if given, otherwise derive from PWD
if [[ -z "$SESSION" ]]; then
    SESSION="$(default_session_name)"
fi

# Existing session? Just reattach (but only if it's an ae session).
if tmux has-session -t "$SESSION" 2>/dev/null; then
    if tmux show-environment -t "$SESSION" AE_SESSION 2>/dev/null | grep -q '^AE_SESSION='; then
        tmux_attach "$SESSION"
    else
        echo "Error: tmux session '$SESSION' exists but is not an ae session." >&2
        exit 1
    fi
fi

# --- Validate config before creating anything ---
MAIN_ALIAS="$(get_config workspace.main)"
LAYOUT="$(get_config workspace.layout)"
WORKERS_RAW="$(get_config workspace.workers)"

# Determine copy mode: CLI flag > config > default (local)
if [[ -n "$COPY_MODE_OVERRIDE" ]]; then
    COPY_MODE="$COPY_MODE_OVERRIDE"
else
    COPY_MODE="$(get_config workspace.copy)"
    COPY_MODE="${COPY_MODE:-local}"
fi

if [[ "$COPY_MODE" != "git" ]] && [[ "$COPY_MODE" != "full" ]] && [[ "$COPY_MODE" != "local" ]]; then
    echo "Error: invalid copy mode '${COPY_MODE}'. Use 'git', 'full', or 'local'." >&2
    exit 1
fi

if [[ -z "$MAIN_ALIAS" ]]; then
    echo "Error: workspace.main not set in $CONFIG_FILE" >&2
    exit 1
fi

MAIN_CMD="$(get_config "agents.${MAIN_ALIAS}")"
if [[ -z "$MAIN_CMD" ]]; then
    echo "Error: agent '${MAIN_ALIAS}' not defined in $CONFIG_FILE" >&2
    exit 1
fi

WORKER_CMDS=()
WORKER_ALIASES=()
if [[ -n "$WORKERS_RAW" ]]; then
    IFS=',' read -ra _aliases <<< "$WORKERS_RAW"
    for alias in "${_aliases[@]}"; do
        alias="$(echo "$alias" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        cmd="$(get_config "agents.${alias}")"
        if [[ -z "$cmd" ]]; then
            echo "Error: agent '${alias}' not defined in $CONFIG_FILE" >&2
            exit 1
        fi
        WORKER_ALIASES+=("$alias")
        WORKER_CMDS+=("$cmd")
    done
fi

# --- Working directory: local, resume existing, or create new ---
ORIGIN_DIR="$PWD"
WORK_DIR="${WORKTREES_DIR}/${SESSION}"
RESUMING=false

if [[ "$COPY_MODE" == "local" ]]; then
    # Local mode: work directly in current directory, no copy
    # Mode collision: error if a stopped worktree/copy session exists with the same name
    if [[ -d "${WORKTREES_DIR}/${SESSION}" ]]; then
        echo "Error: stopped session '${SESSION}' exists as worktree/copy. End or discard it first, or use a different name." >&2
        exit 1
    fi
    WORK_DIR="$PWD"
    # Resume if session meta exists from a previous run (e.g. after reboot)
    if [[ -f "${SESSIONS_DIR}/${SESSION}/meta" ]]; then
        RESUMING=true
        echo "Resuming session ${SESSION}..."
    fi
elif [[ -d "$WORK_DIR" ]]; then
    # Existing worktree — resume it (e.g. after reboot)
    RESUMING=true
    echo "Resuming session ${SESSION}..."
else
    mkdir -p "$WORK_DIR"
    if [[ "$COPY_MODE" == "git" ]]; then
        # Git worktree: fast, shares .git, true isolation
        if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            echo "Creating git worktree..."
            git worktree add --detach "$WORK_DIR" HEAD 2>/dev/null || {
                # Stale registration — prune and retry
                git worktree prune 2>/dev/null || true
                git worktree add --detach "$WORK_DIR" HEAD
            }
        else
            echo "Warning: not a git repo, falling back to full copy." >&2
            COPY_MODE="full"
            echo "Creating full copy..."
            cp -a "$PWD/." "$WORK_DIR"
        fi
    else
        # Full copy: includes untracked files (node_modules, .venv, etc.)
        echo "Creating full copy..."
        cp -a "$PWD/." "$WORK_DIR"
    fi
    echo "Working copy ready."
fi

# --- Create tmux session in the worktree ---
PANE_IDS=()
tmux new-session -d -s "$SESSION" -c "$WORK_DIR"
# Unset env vars that prevent Claude Code from starting inside tmux
tmux set-environment -t "$SESSION" -u CLAUDECODE
tmux set-environment -t "$SESSION" -u CLAUDE_CODE_SESSION

# Tag as ae session and store directories/mode
tmux set-environment -t "$SESSION" AE_SESSION 1
tmux set-environment -t "$SESSION" AE_ORIGIN "$ORIGIN_DIR"
tmux set-environment -t "$SESSION" AE_DIR "$WORK_DIR"
tmux set-environment -t "$SESSION" AE_MODE "$COPY_MODE"

# ae-specific tmux options (session-scoped, doesn't affect other tmux usage)
tmux set-option -t "$SESSION" mouse on
tmux set-option -t "$SESSION" focus-events on 2>/dev/null || true
tmux set-option -t "$SESSION" history-limit 50000
tmux set-option -t "$SESSION" pane-border-status top
tmux set-option -t "$SESSION" pane-border-format " #{pane_index}: #{pane_title} "
tmux set-option -t "$SESSION" status-left "[ae] "
tmux set-option -t "$SESSION" automatic-rename off
tmux rename-window -t "$SESSION" "$SESSION"

PANE_IDS+=("$(tmux display-message -t "$SESSION" -p '#{pane_id}')")

for i in "${!WORKER_CMDS[@]}"; do
    local_id=""
    if [[ "$LAYOUT" == "vertical" ]]; then
        local_id="$(tmux split-window -h -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
    else
        local_id="$(tmux split-window -v -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
    fi
    PANE_IDS+=("$local_id")
done

# Distribute panes evenly
if (( ${#PANE_IDS[@]} > 1 )); then
    if [[ "$LAYOUT" == "vertical" ]]; then
        tmux select-layout -t "$SESSION" even-horizontal
    else
        tmux select-layout -t "$SESSION" even-vertical
    fi
fi

# Label panes with ae:<alias> prefix (for manifest filtering)
tmux select-pane -t "${PANE_IDS[0]}" -T "ae:${MAIN_ALIAS}"
for i in "${!WORKER_ALIASES[@]}"; do
    idx=$(( i + 1 ))
    tmux select-pane -t "${PANE_IDS[$idx]}" -T "ae:${WORKER_ALIASES[$i]}"
done

# --- Generate helper scripts and workspace manifest ---
AE_META="${SESSIONS_DIR}/${SESSION}"
mkdir -p -m 0700 "$AE_META"

# Session metadata (used by ae list/kill for stopped sessions, and by spawn helper)
# Always write full meta: on resume, preserve original mode/origin from existing file
META_MODE="$COPY_MODE"
META_ORIGIN="$ORIGIN_DIR"
if [[ "$RESUMING" == true ]]; then
    # read_session_meta checks new path then falls back to legacy path
    META_MODE="$(read_session_meta "$SESSION" mode)"
    META_ORIGIN="$(read_session_meta "$SESSION" origin)"
    META_MODE="${META_MODE:-$COPY_MODE}"
    META_ORIGIN="${META_ORIGIN:-$ORIGIN_DIR}"
fi

MAIN_TOOL_KIND="$(tool_kind_from_cmd "$MAIN_CMD")"
MAIN_SESSION_ID="$(resolve_agent_session_id "$MAIN_CMD" "main")"

declare -a WORKER_SESSION_IDS=()
for i in "${!WORKER_CMDS[@]}"; do
    WORKER_SESSION_IDS+=("$(resolve_agent_session_id "${WORKER_CMDS[$i]}" "worker.${i}")")
done

# Load spawned agents from previous session (resume only)
declare -a SPAWNED_ALIASES=() SPAWNED_CMDS=() SPAWNED_SESSION_IDS=()
if [[ "$RESUMING" == true ]]; then
    sidx=0
    while true; do
        sentry="$(read_session_meta "$SESSION" "spawned.${sidx}")"
        [[ -z "$sentry" ]] && break
        scmd="$(get_config "agents.${sentry}")"
        if [[ -n "$scmd" ]]; then
            SPAWNED_ALIASES+=("$sentry")
            SPAWNED_CMDS+=("$scmd")
            SPAWNED_SESSION_IDS+=("$(resolve_agent_session_id "$scmd" "spawned.${sidx}")")
        fi
        sidx=$(( sidx + 1 ))
    done

    # Create panes for spawned agents
    for i in "${!SPAWNED_ALIASES[@]}"; do
        local_id=""
        if [[ "$LAYOUT" == "vertical" ]]; then
            local_id="$(tmux split-window -h -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
        else
            local_id="$(tmux split-window -v -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
        fi
        PANE_IDS+=("$local_id")
        tmux select-pane -t "$local_id" -T "ae:${SPAWNED_ALIASES[$i]}"
    done
    # Rebalance if spawned agents were added
    if (( ${#SPAWNED_ALIASES[@]} > 0 )); then
        if [[ "$LAYOUT" == "vertical" ]]; then
            tmux select-layout -t "$SESSION" even-horizontal
        else
            tmux select-layout -t "$SESSION" even-vertical
        fi
    fi
fi

AE_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

cat > "${AE_META}/meta" <<EOF
mode=${META_MODE}
origin=${META_ORIGIN}
session=${SESSION}
work_dir=${WORK_DIR}
layout=${LAYOUT:-vertical}
config=${CONFIG_FILE}
main_pane=${PANE_IDS[0]}
ae_path=${AE_PATH}
agent_session.main=${MAIN_TOOL_KIND}:${MAIN_SESSION_ID}
EOF
# Append worker session IDs
for i in "${!WORKER_CMDS[@]}"; do
    local_kind="$(tool_kind_from_cmd "${WORKER_CMDS[$i]}")"
    echo "agent_session.worker.${i}=${local_kind}:${WORKER_SESSION_IDS[$i]}" >> "${AE_META}/meta"
done
# Append spawned agent info (resume only — fresh starts have no spawned agents yet)
for i in "${!SPAWNED_ALIASES[@]}"; do
    local_kind="$(tool_kind_from_cmd "${SPAWNED_CMDS[$i]}")"
    echo "spawned.${i}=${SPAWNED_ALIASES[$i]}" >> "${AE_META}/meta"
    echo "agent_session.spawned.${i}=${local_kind}:${SPAWNED_SESSION_IDS[$i]}" >> "${AE_META}/meta"
done

# Helper: send <target> <message> — focuses pane, pastes text, submits
cat > "${AE_META}/send" <<'SENDEOF'
#!/usr/bin/env bash
if [[ $# -lt 2 ]]; then
    echo "Usage: send <tmux-target> <message>" >&2
    exit 1
fi
target="$1"; shift
msg="$*"
buf="ae-send-$$"

# Save current pane so we can restore focus after send
current="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
restore_focus() { [[ -n "$current" ]] && tmux select-pane -t "$current" 2>/dev/null; }
trap restore_focus EXIT

# Focus the target pane (TUIs only process input when focused)
tmux select-pane -t "$target"

# Cancel copy-mode if active
tmux send-keys -t "$target" -X cancel 2>/dev/null || true

# Paste via named buffer (avoids races with concurrent sends)
tmux set-buffer -b "$buf" -- "$msg"
tmux paste-buffer -d -b "$buf" -t "$target"

# Brief delay so the TUI can process the pasted text before Enter
sleep 0.1
tmux send-keys -t "$target" Enter
SENDEOF
chmod 0700 "${AE_META}/send"

# Regenerate workspace.md from live tmux pane state
# Scans panes with ae: title prefix, builds agent table
regenerate_manifest() {
    local sess="$1" wdir="$2" origin="$3" mode="$4" main_pane="$5" sessions_dir="$6"
    local manifest="${sessions_dir}/workspace.md"

    # Describe copy mode
    local copy_desc
    case "$mode" in
        git)   copy_desc="You are working on a git worktree (detached HEAD from the origin). Push to remote and merge from there." ;;
        full)  copy_desc="You are working on a full copy of the project. Push to remote and merge from there." ;;
        local) copy_desc="You are working directly in the project directory (local mode). Changes affect the original files immediately." ;;
    esac

    # Build agent rows from live panes (only ae:-prefixed titles)
    local agent_rows=""
    while IFS=$'\t' read -r pane_id pane_title; do
        [[ "$pane_title" == ae:* ]] || continue
        local alias_name="${pane_title#ae:}"
        local role="worker"
        if [[ "$pane_id" == "$main_pane" ]]; then
            role="main"
        fi
        local cmd tool_label
        cmd="$(get_config "agents.${alias_name}")"
        tool_label="$(tool_name_from_cmd "${cmd:-$alias_name}")"
        agent_rows="${agent_rows}| ${alias_name} | ${tool_label} | ${role} | ${pane_id} |
"
    done < <(tmux list-panes -t "$sess" -F '#{pane_id}	#{pane_title}' 2>/dev/null)

    # Collect available aliases from config for spawn section
    local available_aliases=""
    while IFS= read -r entry; do
        if [[ "$entry" == agents.* ]]; then
            local aname="${entry%%=*}"
            aname="${aname#agents.}"
            if [[ -n "$available_aliases" ]]; then
                available_aliases="${available_aliases}, ${aname}"
            else
                available_aliases="$aname"
            fi
        fi
    done < <(parse_config)

    cat > "$manifest" <<EOF
# ae workspace

Session: ${sess}
Origin: ${origin}
Directory: ${wdir}
Mode: ${mode}

${copy_desc}

## Agents

| Alias | Tool | Role | tmux target |
|-------|------|------|-------------|
${agent_rows}
## Communication

Send a message to another agent (sends + presses Enter automatically):
\`\`\`bash
${sessions_dir}/send "<tmux target>" "your message"
\`\`\`

Check another agent's recent output:
\`\`\`bash
tmux capture-pane -t "<tmux target>" -p | tail -20
\`\`\`

## Spawn

Add another agent to this workspace:
\`\`\`bash
${sessions_dir}/spawn <alias> [prompt]
\`\`\`

Available aliases: ${available_aliases} (from ~/.ae/config)

## Rules

- Coordinate file edits -- don't modify the same file simultaneously
- The human can see all panes and may intervene at any time
- Always use the send helper above to communicate with other agents (never raw tmux send-keys)
EOF
}

# Helper: spawn <alias> [prompt] — thin wrapper that calls ae _spawn
cat > "${AE_META}/spawn" <<'SPAWNEOF'
#!/usr/bin/env bash
set -euo pipefail
META_DIR="$(cd "$(dirname "$0")" && pwd)"
AE_PATH="$(grep '^ae_path=' "$META_DIR/meta" | cut -d= -f2-)"
if [[ ! -x "$AE_PATH" ]]; then
    AE_PATH="$(command -v ae 2>/dev/null || true)"
fi
if [[ -z "${AE_PATH:-}" ]] || [[ ! -x "$AE_PATH" ]]; then
    echo "Error: ae not found (expected at $(grep '^ae_path=' "$META_DIR/meta" | cut -d= -f2-))" >&2
    exit 1
fi
if [[ $# -lt 1 ]]; then
    echo "Usage: spawn <alias> [prompt]" >&2
    exit 1
fi
exec "$AE_PATH" _spawn "$META_DIR" "$@"
SPAWNEOF
chmod 0700 "${AE_META}/spawn"

# Generate initial workspace.md from live pane state
regenerate_manifest "$SESSION" "$WORK_DIR" "$ORIGIN_DIR" "$COPY_MODE" "${PANE_IDS[0]}" "$AE_META"

# --- Launch agents ---
# Send agent command with prompt. Some tools (codex resume) don't accept inline
# prompts, so we launch first and send the prompt as user input after a delay.
send_agent_cmd() {
    local pane="$1" cmd="$2" prompt="$3"
    case "$cmd" in
        codex\ resume*)
            # codex resume doesn't accept inline prompts — launch, then send prompt as input
            # Only send prompt if codex is still running (avoids shell execution on resume failure)
            tmux send-keys -t "$pane" "$cmd" C-m
            (sleep 3 && \
                if tmux list-panes -F '#{pane_id} #{pane_current_command}' | grep -q "^${pane} codex$"; then
                    local buf="ae-launch-$$-${pane}"
                    tmux select-pane -t "$pane"
                    tmux set-buffer -b "$buf" -- "$prompt"
                    tmux paste-buffer -d -b "$buf" -t "$pane"
                    sleep 0.1
                    tmux send-keys -t "$pane" Enter
                fi
            ) &
            ;;
        *)
            # Buffer-paste avoids tmux escaping issues; shell-escape single quotes in prompt
            local escaped_prompt="${prompt//\'/\'\\\'\'}"
            local buf="ae-launch-$$-${pane}"
            tmux set-buffer -b "$buf" -- "${cmd} '${escaped_prompt}'"
            tmux paste-buffer -d -b "$buf" -t "$pane"
            tmux send-keys -t "$pane" C-m
            ;;
    esac
}

if [[ "$RESUMING" == true ]]; then
    INITIAL_PROMPT="Resumed after restart. Read ${AE_META}/workspace.md for current pane IDs and continue where you left off."

    # Resume: use session-scoped resume commands (exact conversation, not CWD heuristic)
    MAIN_RESUME="$(resume_cmd_from_cmd "$MAIN_CMD" "$MAIN_SESSION_ID")"
    MAIN_RESUME="$(inject_ae_context "$MAIN_RESUME" "$AE_META" "$SESSION" "$WORK_DIR")"
    send_agent_cmd "${PANE_IDS[0]}" "$MAIN_RESUME" "$INITIAL_PROMPT"
    for i in "${!WORKER_CMDS[@]}"; do
        idx=$(( i + 1 ))
        WORKER_RESUME="$(resume_cmd_from_cmd "${WORKER_CMDS[$i]}" "${WORKER_SESSION_IDS[$i]:-}")"
        WORKER_RESUME="$(inject_ae_context "$WORKER_RESUME" "$AE_META" "$SESSION" "$WORK_DIR")"
        send_agent_cmd "${PANE_IDS[$idx]}" "$WORKER_RESUME" "$INITIAL_PROMPT"
    done
    # Resume spawned agents
    for i in "${!SPAWNED_CMDS[@]}"; do
        sidx=$(( ${#WORKER_CMDS[@]} + i + 1 ))
        SPAWNED_RESUME="$(resume_cmd_from_cmd "${SPAWNED_CMDS[$i]}" "${SPAWNED_SESSION_IDS[$i]:-}")"
        SPAWNED_RESUME="$(inject_ae_context "$SPAWNED_RESUME" "$AE_META" "$SESSION" "$WORK_DIR")"
        send_agent_cmd "${PANE_IDS[$sidx]}" "$SPAWNED_RESUME" "$INITIAL_PROMPT"
    done
else
    INITIAL_PROMPT="Read ${AE_META}/workspace.md for the current agent layout and pane IDs."

    # Fresh start with session-scoped IDs (enables targeted resume later)
    SCOPED_MAIN="$(inject_session_id "$MAIN_CMD" "$MAIN_SESSION_ID")"
    SCOPED_MAIN="$(inject_ae_context "$SCOPED_MAIN" "$AE_META" "$SESSION" "$WORK_DIR")"
    send_agent_cmd "${PANE_IDS[0]}" "$SCOPED_MAIN" "$INITIAL_PROMPT"
    for i in "${!WORKER_CMDS[@]}"; do
        idx=$(( i + 1 ))
        SCOPED_WORKER="$(inject_session_id "${WORKER_CMDS[$i]}" "${WORKER_SESSION_IDS[$i]:-}")"
        SCOPED_WORKER="$(inject_ae_context "$SCOPED_WORKER" "$AE_META" "$SESSION" "$WORK_DIR")"
        send_agent_cmd "${PANE_IDS[$idx]}" "$SCOPED_WORKER" "$INITIAL_PROMPT"
    done
fi

# Capture Codex session IDs in background (runs after launch, doesn't delay attach)
if [[ "$RESUMING" != true ]]; then
    if [[ "$(tool_kind_from_cmd "$MAIN_CMD")" == "codex" ]]; then
        capture_codex_session_id "${PANE_IDS[0]}" "main" "$AE_META" &
    fi
    for i in "${!WORKER_CMDS[@]}"; do
        if [[ "$(tool_kind_from_cmd "${WORKER_CMDS[$i]}")" == "codex" ]]; then
            capture_codex_session_id "${PANE_IDS[$(( i + 1 ))]}" "worker.${i}" "$AE_META" &
        fi
    done
fi

# Focus main pane and attach
tmux select-pane -t "${PANE_IDS[0]}"
tmux_attach "$SESSION"
