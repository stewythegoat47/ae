#!/usr/bin/env bash
# ae - agentic engineering: tmux-based multi-agent workspace
set -euo pipefail

CONFIG_DIR="${HOME}/.ae"
CONFIG_FILE="${CONFIG_DIR}/config"

DEFAULT_CONFIG='[agents]
cc = "claude --permission-mode bypassPermissions --model claude-opus-4-6"
cx = "codex --yolo -m gpt-5.3-codex -c model_reasoning_effort=high"
oc = "opencode"

[workspace]
main = cc
workers = cx
layout = vertical'

# Create default config if missing
if [[ ! -f "$CONFIG_FILE" ]]; then
    mkdir -p "$CONFIG_DIR"
    printf '%s\n' "$DEFAULT_CONFIG" > "$CONFIG_FILE"
    echo "Created default config at $CONFIG_FILE"
fi

# Simple INI parser — outputs section.key=value lines
parse_config() {
    local section=""
    while IFS= read -r line; do
        line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [[ -z "$line" ]] && continue

        if [[ "$line" =~ ^\[([a-zA-Z_]+)\]$ ]]; then
            section="${BASH_REMATCH[1]}"
            continue
        fi

        # Strip comments only outside quoted values
        if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)\ *=\ *\"(.*)\"$ ]]; then
            printf '%s\n' "${section}.${BASH_REMATCH[1]}=${BASH_REMATCH[2]}"
        elif [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)\ *=\ *(.+)$ ]]; then
            local val="${BASH_REMATCH[2]}"
            val="${val%%#*}"
            val="$(echo "$val" | sed 's/[[:space:]]*$//')"
            printf '%s\n' "${section}.${BASH_REMATCH[1]}=${val}"
        else
            # Comment-only or unrecognized line, skip
            continue
        fi
    done < "$CONFIG_FILE"
}

get_config() {
    parse_config | while IFS= read -r entry; do
        if [[ "$entry" == "${1}="* ]]; then
            printf '%s' "${entry#*=}"
        fi
    done
}

# Map command prefix to human-readable tool name
tool_name_from_cmd() {
    case "$1" in
        claude*) echo "claude code" ;;
        codex*)  echo "codex" ;;
        opencode*) echo "opencode" ;;
        *)       echo "$1" ;;
    esac
}

# Derive session name from PWD: /home/user/projects/foo → ae-projects-foo
# Uses a short hash suffix to avoid collisions from path flattening
session_name() {
    local dir="${PWD/#$HOME\//}"
    local hash
    hash="$(printf '%s' "$PWD" | md5sum | cut -c1-6)"
    dir="${dir//\//-}"
    dir="${dir//./_}"
    echo "ae-${dir}-${hash}"
}

# Attach or switch to a tmux session (handles being inside tmux already)
tmux_attach() {
    local target="$1"
    if [[ -n "${TMUX:-}" ]]; then
        exec tmux switch-client -t "$target"
    else
        exec tmux attach-session -t "$target"
    fi
}

# --- Subcommands ---
case "${1:-}" in
    list|ls)
        sessions="$(tmux list-sessions -F '#{session_name} #{session_created} #{session_windows} #{pane_current_path}' 2>/dev/null | grep '^ae-' || true)"
        if [[ -z "$sessions" ]]; then
            echo "No ae sessions."
            exit 0
        fi
        printf '%-40s  %-20s  %s\n' "SESSION" "CREATED" "PANES"
        while IFS= read -r line; do
            name="$(echo "$line" | awk '{print $1}')"
            created="$(echo "$line" | awk '{print $2}')"
            windows="$(echo "$line" | awk '{print $3}')"
            pane_count="$(tmux list-panes -t "$name" 2>/dev/null | wc -l)"
            created_fmt="$(date -d "@${created}" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "$created")"
            printf '%-40s  %-20s  %s\n' "$name" "$created_fmt" "$pane_count"
        done <<< "$sessions"
        exit 0
        ;;
    kill|rm)
        target="${2:-}"
        if [[ -z "$target" ]]; then
            echo "Usage: ae kill <session-name>" >&2
            echo "       ae kill all" >&2
            exit 1
        fi
        if [[ "$target" == "all" ]]; then
            sessions="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^ae-' || true)"
            if [[ -z "$sessions" ]]; then
                echo "No ae sessions."
                exit 0
            fi
            while IFS= read -r s; do
                tmux kill-session -t "$s"
                echo "Killed $s"
            done <<< "$sessions"
        else
            if tmux kill-session -t "$target" 2>/dev/null; then
                echo "Killed $target"
            else
                echo "Session '$target' not found." >&2
                exit 1
            fi
        fi
        exit 0
        ;;
    help|-h|--help)
        echo "ae - agentic engineering: tmux multi-agent workspace"
        echo ""
        echo "Usage:"
        echo "  ae              Start or reattach session for current directory"
        echo "  ae list         List all ae sessions"
        echo "  ae kill <name>  Kill a session (or 'ae kill all')"
        echo "  ae help         Show this help"
        echo ""
        echo "Config: ~/.ae/config"
        exit 0
        ;;
esac

SESSION="$(session_name)"

# Existing session? Just reattach.
if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux_attach "$SESSION"
fi

# Read workspace config
MAIN_ALIAS="$(get_config workspace.main)"
LAYOUT="$(get_config workspace.layout)"
WORKERS_RAW="$(get_config workspace.workers)"

if [[ -z "$MAIN_ALIAS" ]]; then
    echo "Error: workspace.main not set in $CONFIG_FILE" >&2
    exit 1
fi

MAIN_CMD="$(get_config "agents.${MAIN_ALIAS}")"
if [[ -z "$MAIN_CMD" ]]; then
    echo "Error: agent '${MAIN_ALIAS}' not defined in $CONFIG_FILE" >&2
    exit 1
fi

# Parse workers (comma-separated)
WORKER_CMDS=()
WORKER_ALIASES=()
if [[ -n "$WORKERS_RAW" ]]; then
    IFS=',' read -ra _aliases <<< "$WORKERS_RAW"
    for alias in "${_aliases[@]}"; do
        alias="$(echo "$alias" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        cmd="$(get_config "agents.${alias}")"
        if [[ -z "$cmd" ]]; then
            echo "Error: agent '${alias}' not defined in $CONFIG_FILE" >&2
            exit 1
        fi
        WORKER_ALIASES+=("$alias")
        WORKER_CMDS+=("$cmd")
    done
fi

# Create tmux session and capture pane IDs (robust against base-index settings)
# Unset CLAUDECODE so Claude Code doesn't refuse to start inside an existing session
PANE_IDS=()
tmux new-session -d -s "$SESSION" -c "$PWD"
tmux set-environment -t "$SESSION" -u CLAUDECODE
tmux set-environment -t "$SESSION" -u CLAUDE_CODE_SESSION

# ae-specific tmux options (session-scoped, doesn't affect other tmux usage)
tmux set-option -t "$SESSION" mouse on
tmux set-option -t "$SESSION" history-limit 50000
tmux set-option -t "$SESSION" pane-border-status top
tmux set-option -t "$SESSION" pane-border-format " #{pane_index}: #{pane_title} "
tmux set-option -t "$SESSION" status-left "[ae] "
tmux set-option -t "$SESSION" automatic-rename off

PANE_IDS+=("$(tmux display-message -t "$SESSION" -p '#{pane_id}')")

for i in "${!WORKER_CMDS[@]}"; do
    local_id=""
    # vertical = vertical divider = side-by-side, horizontal = stacked
    if [[ "$LAYOUT" == "vertical" ]]; then
        local_id="$(tmux split-window -h -t "$SESSION" -c "$PWD" -P -F '#{pane_id}')"
    else
        local_id="$(tmux split-window -v -t "$SESSION" -c "$PWD" -P -F '#{pane_id}')"
    fi
    PANE_IDS+=("$local_id")
done

# Distribute panes evenly
if (( ${#PANE_IDS[@]} > 1 )); then
    if [[ "$LAYOUT" == "vertical" ]]; then
        tmux select-layout -t "$SESSION" even-horizontal
    else
        tmux select-layout -t "$SESSION" even-vertical
    fi
fi

# Label panes with agent aliases
tmux select-pane -t "${PANE_IDS[0]}" -T "$MAIN_ALIAS"
for i in "${!WORKER_ALIASES[@]}"; do
    idx=$(( i + 1 ))
    tmux select-pane -t "${PANE_IDS[$idx]}" -T "${WORKER_ALIASES[$i]}"
done

# --- Generate workspace manifest ---
AE_DIR="${PWD}/.ae"
mkdir -p "$AE_DIR"

MANIFEST="${AE_DIR}/workspace.md"

# Build agent table rows using actual pane IDs
ALL_ALIASES=("$MAIN_ALIAS" "${WORKER_ALIASES[@]}")
ALL_CMDS=("$MAIN_CMD" "${WORKER_CMDS[@]}")
ALL_ROLES=("main")
for _ in "${WORKER_ALIASES[@]}"; do ALL_ROLES+=("worker"); done

AGENT_ROWS=""
for i in "${!ALL_ALIASES[@]}"; do
    AGENT_ROWS="${AGENT_ROWS}| ${ALL_ALIASES[$i]} | $(tool_name_from_cmd "${ALL_CMDS[$i]}") | ${ALL_ROLES[$i]} | ${PANE_IDS[$i]} |
"
done

cat > "$MANIFEST" <<EOF
# ae workspace

Session: ${SESSION}
Directory: ${PWD}

## Agents

| Alias | Tool | Role | tmux target |
|-------|------|------|-------------|
${AGENT_ROWS}
## Communication

Send a message to another agent and press Enter:
\`\`\`bash
tmux send-keys -t "<tmux target>" "your message" Enter
\`\`\`
IMPORTANT: "Enter" MUST be a separate argument OUTSIDE the quotes. It is a tmux key name that presses Enter.
Wrong: tmux send-keys -t "%1" "your message Enter"   -- this sends literal text "Enter"
Right: tmux send-keys -t "%1" "your message" Enter    -- this sends the message then presses Enter

Check another agent's recent output:
\`\`\`bash
tmux capture-pane -t "<tmux target>" -p | tail -20
\`\`\`

## Rules

- Coordinate file edits -- don't modify the same file simultaneously
- The human can see all panes and may intervene at any time
- Use tmux send-keys to delegate tasks or request reviews from other agents
EOF

INITIAL_PROMPT="You are in a multi-agent ae workspace. Read .ae/workspace.md for details about other agents and how to communicate with them."

# Launch agents with initial workspace awareness prompt
tmux send-keys -t "${PANE_IDS[0]}" "$MAIN_CMD \"$INITIAL_PROMPT\"" C-m
for i in "${!WORKER_CMDS[@]}"; do
    idx=$(( i + 1 ))
    tmux send-keys -t "${PANE_IDS[$idx]}" "${WORKER_CMDS[$i]} \"$INITIAL_PROMPT\"" C-m
done

# Focus main pane and attach
tmux select-pane -t "${PANE_IDS[0]}"
tmux_attach "$SESSION"
