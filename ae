#!/usr/bin/env bash
# ae - agentic engineering: tmux-based multi-agent workspace
set -euo pipefail

CONFIG_DIR="${HOME}/.ae"
CONFIG_FILE="${CONFIG_DIR}/config"
WORKTREES_DIR="${CONFIG_DIR}/worktrees"
SESSIONS_DIR="${CONFIG_DIR}/sessions"

# Per-project config override (optional)
AE_LOCAL_CONFIG=""
[[ -f ".ae/config" ]] && AE_LOCAL_CONFIG="$(pwd)/.ae/config"

# Optional: isolated tmux server (for testing or multi-instance use)
if [[ -n "${AE_TMUX_SERVER:-}" ]]; then
    tmux() { command tmux -L "$AE_TMUX_SERVER" "$@"; }
fi

# --- Function index ---
#   Config:     parse_config, get_config
#   Helpers:    tool_name_from_cmd, tool_kind_from_cmd, default_session_name, tmux_attach, gen_uuid, detect_current_session
#   Resume:     strip_session_flags, resume_cmd_from_cmd, inject_session_id, inject_ae_context, resolve_agent_session_id
#   Session:    read_session_meta, list_ae_sessions, iter_stopped_sessions, cleanup_session
#   End/branch: sanitize_branch_name, resolve_session_workdir, end_session
#   Commands:   cmd_list, cmd_status, cmd_stop, cmd_end, cmd_help, _cmd_spawn
#   Manifest:   regenerate_manifest
#   Launch:     send_agent_cmd, capture_codex_session_id

DEFAULT_CONFIG='[agents]
claude = "claude --permission-mode bypassPermissions --model claude-opus-4-6"
codex = "codex --yolo -m gpt-5.3-codex -c model_reasoning_effort=high"
opencode = "opencode"

[workspace]
main = claude:lead
layout = vertical'

# Create default config if missing
if [[ ! -f "$CONFIG_FILE" ]]; then
    mkdir -p "$CONFIG_DIR"
    printf '%s\n' "$DEFAULT_CONFIG" > "$CONFIG_FILE"
    echo "Created default config at $CONFIG_FILE"
fi

# Simple INI parser — outputs section.key=value lines
# Reads global config, then per-project .ae/config (local values shadow global)
parse_config() {
    local section="" file
    for file in "$CONFIG_FILE" "${AE_LOCAL_CONFIG:-}"; do
        [[ -n "$file" ]] && [[ -f "$file" ]] || continue
        section=""
        while IFS= read -r line; do
            line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
            [[ -z "$line" ]] && continue

            if [[ "$line" =~ ^\[([a-zA-Z_-]+)\]$ ]]; then
                section="${BASH_REMATCH[1]}"
                continue
            fi

            # Strip comments only outside quoted values
            if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_-]*)\ *=\ *\"(.*)\"$ ]]; then
                printf '%s\n' "${section}.${BASH_REMATCH[1]}=${BASH_REMATCH[2]}"
            elif [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_-]*)\ *=\ *(.+)$ ]]; then
                local val="${BASH_REMATCH[2]}"
                val="${val%%#*}"
                val="$(echo "$val" | sed 's/[[:space:]]*$//')"
                printf '%s\n' "${section}.${BASH_REMATCH[1]}=${val}"
            else
                continue
            fi
        done < "$file"
    done
}

# Last match wins — local config overrides global
get_config() {
    local result=""
    while IFS= read -r entry; do
        if [[ "$entry" == "${1}="* ]]; then
            result="${entry#*=}"
        fi
    done < <(parse_config)
    printf '%s' "$result"
}

# Map command prefix to human-readable tool name
tool_name_from_cmd() {
    case "$1" in
        claude*) echo "claude code" ;;
        codex*)  echo "codex" ;;
        gemini*) echo "gemini cli" ;;
        opencode*) echo "opencode" ;;
        *)       echo "$1" ;;
    esac
}

# Strip session/resume flags from a command (whole-token matching to avoid mangling e.g. --continue-on-error)
strip_session_flags() {
    echo "$1" | sed \
        -e 's/\(^\|  *\)--session-id[= ][^ ]*/\1/g' \
        -e 's/\(^\|  *\)--resume[= ][^ ]*/\1/g' \
        -e 's/\(^\|  *\)--continue\(  *\|$\)/\1\2/g' \
        -e 's/  */ /g; s/^ //; s/ $//'
}

# Strip gemini prompt injection flags (-i '...' / --prompt-interactive '...')
# Only called for gemini commands. We control the format: always single-quoted via inject_ae_context.
strip_gemini_prompt_flags() {
    echo "$1" | sed \
        -e "s/ --prompt-interactive '[^']*'//g" \
        -e "s/ -i '[^']*'//g" \
        -e 's/  */ /g; s/^ //; s/ $//'
}

# Derive resume command with session-scoped ID (survives multiple concurrent sessions)
# Falls back to heuristic resume, then fresh start
resume_cmd_from_cmd() {
    local cmd="$1" session_id="${2:-}"
    # Treat "pending" (uncaptured) as no session ID — fall back to fresh start
    [[ "$session_id" == "pending" ]] && session_id=""
    local clean
    clean="$(strip_session_flags "$cmd")"
    case "$cmd" in
        claude*)
            if [[ -n "$session_id" ]]; then
                echo "${clean} --resume ${session_id}"
            else
                echo "${clean} --continue"
            fi
            ;;
        codex*)
            if [[ -n "$session_id" ]]; then
                # Preserve flags (e.g. --yolo) from original command for the resume subcommand
                local codex_flags="${clean#codex}"
                codex_flags="${codex_flags# }"  # strip leading space
                if [[ -n "$codex_flags" ]]; then
                    echo "codex ${codex_flags} resume ${session_id}"
                else
                    echo "codex resume ${session_id}"
                fi
            else
                echo "$clean"  # fresh start (--last is unreliable for concurrent sessions)
            fi
            ;;
        gemini*)
            clean="$(strip_gemini_prompt_flags "$clean")"
            echo "${clean} --resume latest"  # index-based only, no UUID scoping
            ;;
        *)  echo "$clean" ;;  # fresh start for unknown agents
    esac
}

# Inject agent-scoped session ID into start command (enables targeted resume later)
inject_session_id() {
    local cmd="$1" session_id="$2"
    [[ "$session_id" == "pending" ]] && session_id=""
    local clean
    clean="$(strip_session_flags "$cmd")"
    if [[ -n "$session_id" ]]; then
        case "$cmd" in
            claude*) echo "${clean} --session-id ${session_id}" ;;
            *)       echo "$clean" ;;
        esac
    else
        echo "$clean"
    fi
}

# Build ae workspace context string (shared by inject_ae_context and initial prompt fallback)
build_ae_context() {
    local meta_dir="$1" session="${2:-}" work_dir="${3:-}"
    local ctx="You are in an ae multi-agent workspace. Session: ${session}. Directory: ${work_dir}. Communication: send a message to another agent: ${meta_dir}/send \"<agent_name>\" \"<message>\". When another agent asks you something, always reply back via send to that agent when done. Do not poll or check panes for replies — answers arrive as incoming messages. Spawn a new agent: ${meta_dir}/spawn <alias>:<name> [prompt] — give a descriptive role name. See ${meta_dir}/workspace.md for agent names and details."
    local user_instr
    user_instr="$(get_config prompt.instructions)"
    [[ -n "$user_instr" ]] && ctx="${ctx} --- Workspace instructions: ${user_instr}"
    printf '%s' "$ctx"
}

# Inject ae workspace context into agent system prompt (survives context compaction)
# Claude Code: --append-system-prompt; Codex: -c developer_instructions; others: initial prompt
inject_ae_context() {
    local cmd="$1" meta_dir="$2" session="${3:-}" work_dir="${4:-}" slot="${5:-}"
    local ctx
    ctx="$(build_ae_context "$meta_dir" "$session" "$work_dir")"
    case "$cmd" in
        claude*)
            local escaped="${ctx//\'/\'\\\'\'}"
            echo "${cmd} --append-system-prompt '${escaped}'"
            ;;
        codex*)
            # Tell codex to self-register its session ID by running the slot-scoped helper script
            local slot_arg=""
            [[ -n "$slot" ]] && slot_arg=" ${slot}"
            local full_ctx="${ctx} --- CRITICAL FIRST TASK: Enable session resume by running: ${meta_dir}/register-sid${slot_arg} — do this NOW before anything else."
            local escaped="${full_ctx//\'/\'\\\'\'}"
            echo "${cmd} -c developer_instructions='${escaped}'"
            ;;
        gemini*)
            local full_ctx="${ctx} --- IMPORTANT: This is context only. Do NOT act on it. Wait for the user to give you a task."
            local escaped="${full_ctx//\'/\'\\\'\'}"
            echo "${cmd} -i '${escaped}'"
            ;;
        *) echo "$cmd" ;;
    esac
}

# For agents without system prompt injection, return context as emphasized initial message
initial_prompt_for_cmd() {
    local cmd="$1" meta_dir="$2" session="${3:-}" work_dir="${4:-}"
    case "$cmd" in
        claude*|gemini*) echo "" ;;  # context injected via CLI flag
        codex*) echo "Go" ;;  # codex needs a user message to act on developer_instructions
        opencode*)
            local ctx
            ctx="$(build_ae_context "$meta_dir" "$session" "$work_dir")"
            printf '%s' "IMPORTANT — read and internalize these workspace instructions before doing anything else. They apply for the ENTIRE session. ${ctx} Confirm you understood by briefly listing the other agents and available tools (send, spawn)."
            ;;
        *) echo "" ;;  # unknown agents: no injection (no reliable delivery method)
    esac
}

# Generate a UUID (for agent session scoping)
gen_uuid() {
    if [[ -f /proc/sys/kernel/random/uuid ]]; then
        cat /proc/sys/kernel/random/uuid
    elif command -v uuidgen >/dev/null 2>&1; then
        uuidgen
    else
        echo "ae: no UUID generator available (need /proc/sys/kernel/random/uuid or uuidgen)" >&2
        echo "ae: install util-linux or uuid-runtime, or ensure /proc is mounted" >&2
        return 1
    fi
}

# Detect current ae session when running inside tmux (for ae end/status without name)
detect_current_session() {
    if [[ -n "${TMUX:-}" ]]; then
        local session_name
        session_name="$(tmux display-message -p '#{session_name}' 2>/dev/null)" || return 1
        if [[ -d "${SESSIONS_DIR}/${session_name}" ]]; then
            echo "$session_name"
            return 0
        fi
    fi
    return 1
}

# Detect tool kind from command (for staleness checks on resume)
tool_kind_from_cmd() {
    case "$1" in
        claude*)   echo "claude" ;;
        codex*)    echo "codex" ;;
        gemini*)   echo "gemini" ;;
        opencode*) echo "opencode" ;;
        *)         echo "unknown" ;;
    esac
}

# Best-effort: capture Codex session ID post-launch (codex prints "session id: <uuid>" on startup)
# Wait for codex to self-register its session ID via developer_instructions,
# then update the meta file. Falls back to TUI scraping if self-registration doesn't happen.
capture_codex_session_id() {
    local pane="$1" slot="$2" meta_dir="$3"
    local sid_file="${meta_dir}/codex.${slot}.sid"
    local captured=""
    # Poll for self-registered session ID (codex writes to codex.sid via developer_instructions)
    local attempt
    for attempt in 1 2 3 4 5 6; do
        sleep 5
        if [[ -f "$sid_file" ]]; then
            captured="$(< "$sid_file")"
            captured="${captured//[$'\n\r ']/}"  # strip whitespace
            rm -f "$sid_file"
            break
        fi
    done
    # Fallback: scrape TUI output (legacy, less reliable)
    if [[ -z "$captured" ]]; then
        captured="$(tmux capture-pane -t "$pane" -p 2>/dev/null | grep -oP 'session id: \K[0-9a-f-]+' | head -1 || true)"
    fi
    if [[ -n "$captured" ]]; then
        (
            flock -w 5 200 || exit 1
            local escaped_slot="${slot//./\\.}"
            sed -i "s/^agent\.${escaped_slot}=\([^:]*:[^:]*:\).*/agent.${slot}=\1${captured}/" "$meta_dir/meta"
        ) 200>"$meta_dir/meta.lock"
    fi
}

# Generate or restore a session-scoped agent ID
# Uses globals $RESUMING and $SESSION when available (main launch path)
# For _cmd_spawn: RESUMING is unset → always generates new IDs
resolve_agent_session_id() {
    local cmd="$1" slot="$2"
    local kind
    kind="$(tool_kind_from_cmd "$cmd")"
    local session_id=""
    if [[ "${RESUMING:-}" == true ]] && [[ -n "${SESSION:-}" ]]; then
        local stored
        stored="$(read_session_meta "$SESSION" "agent.${slot}")"
        if [[ -n "$stored" ]]; then
            # Format: alias:name:session_id
            local stored_id="${stored##*:}"
            if [[ "$stored_id" != "pending" && -n "$stored_id" ]]; then
                session_id="$stored_id"
            fi
        fi
    fi
    if [[ -z "$session_id" ]]; then
        case "$cmd" in
            claude*) session_id="$(gen_uuid)" ;;
            *)       session_id="pending" ;;
        esac
    fi
    echo "$session_id"
}

# Derive default session name from PWD
default_session_name() {
    local dir="${PWD/#$HOME\//}"
    local hash
    hash="$(printf '%s' "$PWD" | md5sum | cut -c1-6)"
    dir="${dir//\//-}"
    dir="${dir//./_}"
    echo "ae-${dir}-${hash}"
}

# Attach or switch to a tmux session (handles being inside tmux already)
tmux_attach() {
    local target="$1"
    if [[ -n "${TMUX:-}" ]]; then
        exec tmux switch-client -t "$target"
    else
        exec tmux attach-session -t "$target"
    fi
}

# Read a session's metadata file (mode, origin)
read_session_meta() {
    local session_name="$1" key="$2"
    local meta="${SESSIONS_DIR}/${session_name}/meta"
    # Backward compat: try old worktree-nested path
    if [[ ! -f "$meta" ]]; then
        meta="${WORKTREES_DIR}/${session_name}/.ae/${session_name}/meta"
    fi
    if [[ -f "$meta" ]]; then
        while IFS='=' read -r k v; do
            if [[ "$k" == "$key" ]]; then
                printf '%s' "$v"
                return
            fi
        done < "$meta"
    fi
}

# List all ae sessions (tagged with AE_SESSION env var)
list_ae_sessions() {
    local sessions=""
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if tmux show-environment -t "$name" AE_SESSION 2>/dev/null | grep -q '^AE_SESSION='; then
            sessions="${sessions}${name}\n"
        fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
    printf '%b' "$sessions"
}

# Iterate stopped sessions (on disk but not running), de-duplicated across SESSIONS_DIR and WORKTREES_DIR
iter_stopped_sessions() {
    declare -A _seen=()
    for dir in "$SESSIONS_DIR" "$WORKTREES_DIR"; do
        [[ -d "$dir" ]] || continue
        for entry in "$dir"/*/; do
            [[ -d "$entry" ]] || continue
            local name
            name="$(basename "$entry")"
            [[ -n "${_seen[$name]:-}" ]] && continue
            tmux has-session -t "$name" 2>/dev/null && continue
            _seen[$name]=1
            echo "$name"
        done
    done
}

# Clean up session resources (mode-aware)
cleanup_session() {
    local session_name="$1"
    local wt="${WORKTREES_DIR}/${session_name}"

    # Read mode and origin from tmux env (running sessions) then on-disk meta (stopped)
    local mode origin
    mode="$(tmux show-environment -t "$session_name" AE_MODE 2>/dev/null | sed 's/^AE_MODE=//' || true)"
    origin="$(tmux show-environment -t "$session_name" AE_ORIGIN 2>/dev/null | sed 's/^AE_ORIGIN=//' || true)"
    if [[ -z "$mode" ]]; then
        mode="$(read_session_meta "$session_name" mode)"
    fi
    if [[ -z "$origin" ]]; then
        origin="$(read_session_meta "$session_name" origin)"
    fi

    # Always clean session state from SESSIONS_DIR
    rm -rf "${SESSIONS_DIR}/${session_name}"
    # Legacy cleanup: old worktree-nested and local-mode paths
    rm -rf "${WORKTREES_DIR}/${session_name}/.ae/${session_name}" 2>/dev/null || true
    if [[ -n "$origin" ]] && [[ -d "${origin}/.ae/${session_name}" ]]; then
        rm -rf "${origin}/.ae/${session_name}"
    fi

    if [[ "$mode" == "local" ]]; then
        echo "Cleaned up local session $session_name"
        return 0
    fi

    [[ -d "$wt" ]] || return 0

    if [[ "$mode" == "git" ]] && [[ -n "$origin" ]]; then
        git -C "$origin" worktree remove --force "$wt" 2>/dev/null || rm -rf "$wt"
        git -C "$origin" worktree prune 2>/dev/null || true
    else
        rm -rf "$wt"
    fi
    echo "Removed worktree for $session_name"
}

# Sanitize session name to valid git branch name
sanitize_branch_name() {
    local name="$1"
    # Strip ae- prefix for cleaner branch names
    name="${name#ae-}"
    # Replace invalid chars with -, collapse repeats, trim edges
    name="$(echo "$name" | sed 's/[^a-zA-Z0-9._-]/-/g; s/--*/-/g; s/^-//; s/-$//')"
    echo "ae/${name}"
}

# Resolve work directory for a session (running or stopped)
resolve_session_workdir() {
    local session_name="$1"
    local wdir=""
    # Try tmux env first (running session)
    wdir="$(tmux show-environment -t "$session_name" AE_DIR 2>/dev/null | sed 's/^AE_DIR=//' || true)"
    if [[ -z "$wdir" ]] || [[ ! -d "$wdir" ]]; then
        # Try on-disk meta (stopped session)
        wdir="$(read_session_meta "$session_name" work_dir)"
    fi
    if [[ -z "$wdir" ]] || [[ ! -d "$wdir" ]]; then
        # Fallback: standard worktree path
        wdir="${WORKTREES_DIR}/${session_name}"
    fi
    echo "$wdir"
}

# End a session: commit dirty state, push to ae/<branch>, then clean up
# Returns non-zero on failure (session is preserved on failure)
end_session() {
    local session_name="$1"

    # Resolve mode and origin
    local mode origin wdir
    mode="$(tmux show-environment -t "$session_name" AE_MODE 2>/dev/null | sed 's/^AE_MODE=//' || true)"
    origin="$(tmux show-environment -t "$session_name" AE_ORIGIN 2>/dev/null | sed 's/^AE_ORIGIN=//' || true)"
    if [[ -z "$mode" ]]; then
        mode="$(read_session_meta "$session_name" mode)"
    fi
    if [[ -z "$origin" ]]; then
        origin="$(read_session_meta "$session_name" origin)"
    fi
    wdir="$(resolve_session_workdir "$session_name")"

    # Local mode: just clean up (no work to preserve — files are in original dir)
    if [[ "$mode" == "local" ]]; then
        if tmux has-session -t "$session_name" 2>/dev/null; then
            tmux kill-session -t "$session_name"
        fi
        cleanup_session "$session_name"
        echo "Ended local session $session_name"
        return 0
    fi

    # git/full mode: commit + push if in a git repo
    if [[ -d "$wdir" ]] && git -C "$wdir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        # Check for uncommitted changes
        if ! git -C "$wdir" diff --quiet 2>/dev/null || ! git -C "$wdir" diff --cached --quiet 2>/dev/null || \
           [[ -n "$(git -C "$wdir" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
            echo "Committing changes in $session_name..."
            git -C "$wdir" add -A
            local ts
            ts="$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
            if ! git -C "$wdir" commit -m "ae: end session ${session_name}" -m "Ended: ${ts}"; then
                echo "Error: commit failed. Session preserved — fix manually and retry." >&2
                echo "  Working directory: $wdir" >&2
                return 1
            fi
        fi

        # Check if there's anything to push (HEAD not already on a remote branch)
        local needs_push=false
        if git -C "$wdir" remote get-url origin >/dev/null 2>&1; then
            # Fetch silently to check against remote state
            git -C "$wdir" fetch origin --quiet 2>/dev/null || true
            if ! git -C "$wdir" branch -r --contains HEAD 2>/dev/null | grep -q .; then
                needs_push=true
            fi
        fi

        if [[ "$needs_push" == true ]]; then
            local branch
            branch="$(sanitize_branch_name "$session_name")"
            echo "Pushing to origin/${branch}..."

            # Show what we're pushing (count files changed across all unpushed commits)
            local file_count
            file_count="$(git -C "$wdir" diff --name-only "$(git -C "$wdir" merge-base HEAD origin/HEAD 2>/dev/null || echo HEAD~1)" HEAD 2>/dev/null | wc -l || echo "?")"
            echo "  ${file_count} file(s) changed"

            if ! git -C "$wdir" push -u origin "HEAD:refs/heads/${branch}"; then
                echo "Error: push failed. Session preserved — fix manually and retry." >&2
                echo "  Working directory: $wdir" >&2
                echo "  To retry: cd $wdir && git push -u origin HEAD:refs/heads/${branch}" >&2
                return 1
            fi
            echo "Pushed to origin/${branch}"
        else
            if ! git -C "$wdir" remote get-url origin >/dev/null 2>&1; then
                echo "No remote 'origin' — skipping push."
            else
                echo "No new commits to push."
            fi
        fi
    else
        echo "Error: working directory is not a git repo — cannot preserve work." >&2
        echo "  Use 'ae end $session_name' to end the session." >&2
        return 1
    fi

    # All good — clean up
    if tmux has-session -t "$session_name" 2>/dev/null; then
        tmux kill-session -t "$session_name"
    fi
    cleanup_session "$session_name"
    echo "Ended $session_name"
    return 0
}

# --- Subcommands ---

# Parse agent entry (alias:name:session_id) and print "alias:name short_sid"
_parse_agent_entry() {
    local val="$1"
    # Format: alias:name:session_id
    local alias="${val%%:*}"
    local rest="${val#*:}"
    local name="${rest%%:*}"
    local sid="${rest#*:}"
    local short="-"
    [[ -n "$sid" && "$sid" != "pending" ]] && short="${sid:0:8}"
    printf '%s:%s\t%s\n' "$alias" "$name" "$short"
}

cmd_list() {
    local sessions has_output=false
    # Column widths: SESSION(24) STATUS(8) MODE(10) ORIGIN(rest)
    local hdr='%-24s  %-8s  %-10s  %s\n'
    local indent='%-24s  %-8s  %-10s  %s\n'  # same widths for target indent
    sessions="$(list_ae_sessions)"
    if [[ -n "$sessions" ]]; then
        has_output=true
        printf "$hdr" "SESSION" "STATUS" "MODE" "ORIGIN"
        while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            local meta="${SESSIONS_DIR}/${name}/meta"
            local meta_blob=""
            [[ -f "$meta" ]] && meta_blob="$(<"$meta")"
            local origin mode workdir
            origin="$(tmux show-environment -t "$name" AE_ORIGIN 2>/dev/null | sed 's/^AE_ORIGIN=//' || true)"
            [[ -z "$origin" ]] && origin="$(echo "$meta_blob" | sed -n 's/^origin=//p')"
            origin="${origin:-?}"
            mode="$(tmux show-environment -t "$name" AE_MODE 2>/dev/null | sed 's/^AE_MODE=//' || true)"
            [[ -z "$mode" ]] && mode="$(echo "$meta_blob" | sed -n 's/^mode=//p')"
            mode="${mode:-?}"
            workdir="$(tmux show-environment -t "$name" AE_DIR 2>/dev/null | sed 's/^AE_DIR=//' || true)"
            [[ -z "$workdir" ]] && workdir="$(echo "$meta_blob" | sed -n 's/^work_dir=//p')"
            printf "$hdr" "$name" "running" "$mode" "$origin"
            [[ "$mode" != "local" && -n "$workdir" ]] && printf "$indent" "" "" "" "  -> $workdir"
            # Build alive map from tmux panes (one tmux call)
            declare -A _alive=()
            while IFS=$'\t' read -r ae_agent pane_cmd; do
                [[ -n "$ae_agent" ]] || continue
                case "$pane_cmd" in
                    bash|fish|zsh|sh|dash) _alive["$ae_agent"]="!" ;;
                    *) _alive["$ae_agent"]="" ;;
                esac
            done < <(tmux list-panes -t "$name" -F '#{@ae_agent}	#{pane_current_command}' 2>/dev/null)
            while IFS='=' read -r mk mv; do
                [[ "$mk" == agent.* ]] || continue
                local aname asid
                IFS=$'\t' read -r aname asid < <(_parse_agent_entry "$mv")
                local marker="${_alive[$aname]:-}"
                printf "  %-22s  %-8s  %s\n" "$aname" "$asid" "$marker"
            done <<< "$meta_blob"
            unset _alive
        done <<< "$sessions"
    fi
    while IFS= read -r name; do
        if [[ "$has_output" == false ]]; then
            printf "$hdr" "SESSION" "STATUS" "MODE" "ORIGIN"
            has_output=true
        fi
        local meta="${SESSIONS_DIR}/${name}/meta"
        local meta_blob=""
        [[ -f "$meta" ]] && meta_blob="$(<"$meta")"
        local mode origin workdir
        mode="$(echo "$meta_blob" | sed -n 's/^mode=//p')"
        mode="${mode:-?}"
        origin="$(echo "$meta_blob" | sed -n 's/^origin=//p')"
        origin="${origin:--}"
        workdir="$(echo "$meta_blob" | sed -n 's/^work_dir=//p')"
        printf "$hdr" "$name" "stopped" "$mode" "$origin"
        [[ "$mode" != "local" && -n "$workdir" ]] && printf "$indent" "" "" "" "  -> $workdir"
        while IFS='=' read -r mk mv; do
            [[ "$mk" == agent.* ]] || continue
            local aname asid
            IFS=$'\t' read -r aname asid < <(_parse_agent_entry "$mv")
            printf "  %-22s  %s\n" "$aname" "$asid"
        done <<< "$meta_blob"
    done < <(iter_stopped_sessions)
    if [[ "$has_output" == false ]]; then
        echo "No ae sessions."
    fi
}

cmd_status() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        target="$(detect_current_session 2>/dev/null)" || {
            echo "Usage: ae status [session-name]" >&2
            echo "(Run inside an ae tmux session to check status without specifying the name.)" >&2
            return 1
        }
    fi
    if ! tmux has-session -t "$target" 2>/dev/null; then
        if [[ -d "${SESSIONS_DIR}/${target}" ]]; then
            echo "Session '$target' is stopped."
            return 0
        fi
        echo "Session '$target' not found." >&2
        return 1
    fi
    local found=false
    while IFS=$'\t' read -r pane_id ae_agent; do
        [[ -n "$ae_agent" ]] || continue
        found=true
        echo "── ${ae_agent} (${pane_id}) ──"
        tmux capture-pane -t "$pane_id" -p 2>/dev/null | grep -v '^$' | tail -15
        echo ""
    done < <(tmux list-panes -t "$target" -F '#{pane_id}	#{@ae_agent}' 2>/dev/null)
    if [[ "$found" == false ]]; then
        echo "No agent panes in session '$target'."
    fi
}

cmd_stop() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        target="$(detect_current_session 2>/dev/null)" || {
            echo "Usage: ae stop [session-name]" >&2
            echo "       ae stop all" >&2
            echo "(Run inside an ae tmux session to stop it without specifying the name.)" >&2
            return 1
        }
    fi
    if [[ "$target" == "all" ]]; then
        local found=false
        local sessions
        sessions="$(list_ae_sessions)"
        if [[ -n "$sessions" ]]; then
            while IFS= read -r s; do
                [[ -z "$s" ]] && continue
                found=true
                tmux kill-session -t "$s" 2>/dev/null || true
                echo "Stopped $s"
            done <<< "$sessions"
        fi
        if [[ "$found" == false ]]; then
            echo "No running ae sessions."
        fi
    else
        if tmux has-session -t "$target" 2>/dev/null; then
            tmux kill-session -t "$target"
            echo "Stopped $target"
        else
            echo "Session '$target' is not running." >&2
            return 1
        fi
    fi
}

cmd_end() {
    local target="${1:-}" force=false
    if [[ "$target" == "-f" || "$target" == "--force" ]]; then
        force=true
        target="${2:-}"
    elif [[ "${2:-}" == "-f" || "${2:-}" == "--force" ]]; then
        force=true
    fi
    if [[ -z "$target" ]]; then
        target="$(detect_current_session 2>/dev/null)" || {
            echo "Usage: ae end [-f] [session-name]" >&2
            echo "       ae end [-f] all" >&2
            echo "(Run inside an ae tmux session to end it without specifying the name.)" >&2
            return 1
        }
    fi
    if [[ "$force" != true ]]; then
        printf "End session '$target'? This will commit, push, and clean up. [y/N] "
        read -r -n 1 reply
        echo
        if [[ ! "$reply" =~ ^[Yy]$ ]]; then
            echo "Aborted."
            return 0
        fi
    fi
    if [[ "$target" == "all" ]]; then
        local found=false failures=0
        local sessions
        sessions="$(list_ae_sessions)"
        if [[ -n "$sessions" ]]; then
            while IFS= read -r s; do
                [[ -z "$s" ]] && continue
                found=true
                end_session "$s" || failures=$(( failures + 1 ))
            done <<< "$sessions"
        fi
        while IFS= read -r name; do
            found=true
            end_session "$name" || failures=$(( failures + 1 ))
        done < <(iter_stopped_sessions)
        if [[ "$found" == false ]]; then
            echo "No ae sessions."
        elif (( failures > 0 )); then
            echo "${failures} session(s) failed to end. See errors above." >&2
            return 1
        fi
    else
        if tmux has-session -t "$target" 2>/dev/null; then
            end_session "$target" || return 1
        elif [[ ! "$target" =~ [/] ]] && [[ -d "${SESSIONS_DIR}/${target}" ]]; then
            end_session "$target" || return 1
        elif [[ ! "$target" =~ [/] ]] && [[ -d "${WORKTREES_DIR}/${target}" ]]; then
            end_session "$target" || return 1
        else
            echo "Session '$target' not found." >&2
            return 1
        fi
    fi
}


cmd_help() {
    echo "ae - agentic engineering: tmux multi-agent workspace"
    echo ""
    echo "Usage:"
    echo "  ae                     Start or reattach default session (local)"
    echo "  ae <name>              Start or reattach a named session"
    echo "  ae <name> use <alias>  Start session with a specific agent as main"
    echo "  ae --local [name]      Start session in current directory (default)"
    echo "  ae --copy [name]       Start session with full copy (includes untracked files)"
    echo "  ae --worktree [name]   Start session with git worktree (tracked files only)"
    echo "  ae list                List all ae sessions"
    echo "  ae status [name]       Show recent agent output without attaching"
    echo "  ae stop [name]         Stop session, keep state for resume (or 'ae stop all')"
    echo "  ae end|rm [-f] [name]  End session: commit, push, clean up (or 'ae end all')"
    echo "  ae help                Show this help"
    echo ""
    echo "Modes: --local (default), --copy (full cp -a), --worktree (git worktree)."
    echo "Sessions persist across reboots. Agents with session support resume conversations; others start fresh."
    echo "When inside an ae session, stop/end/status work without specifying the name."
    echo ""
    echo "Config: ~/.ae/config (per-project override: .ae/config in project dir)"
}

# Internal: spawn a new agent pane (called via spawn helper → ae _spawn)
_cmd_spawn() {
    local meta_dir="$1"; shift
    local alias_arg="$1"; shift
    local alias_name="${alias_arg%%:*}"
    local spawn_name=""
    [[ "$alias_arg" == *:* ]] && spawn_name="${alias_arg#*:}"
    # Name must not contain ':' (used as delimiter in meta format)
    if [[ "$spawn_name" == *:* ]]; then
        echo "Error: agent name cannot contain ':' — use alias:name format" >&2
        return 1
    fi
    local user_prompt="${*:-}"

    # Resolve caller's agent identity (the pane that ran spawn)
    local caller_pane caller_agent
    caller_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
    caller_agent=""
    if [[ -n "$caller_pane" ]]; then
        caller_agent="$(tmux display-message -t "$caller_pane" -p '#{@ae_agent}' 2>/dev/null || true)"
    fi

    # Build spawn prompt with reply-back instruction
    local prompt
    if [[ -n "$user_prompt" ]]; then
        if [[ -n "$caller_agent" ]]; then
            prompt="${user_prompt} — When done, reply back via: ${meta_dir}/send \"${caller_agent}\" \"<your reply>\""
        else
            prompt="$user_prompt"
        fi
    else
        prompt="You were spawned into an ae workspace. Read ${meta_dir}/workspace.md for details."
    fi

    # Read meta
    declare -A meta=()
    while IFS='=' read -r k v; do
        case "$k" in
            mode|origin|session|work_dir|layout|config|main_pane) meta["$k"]="$v" ;;
        esac
    done < "$meta_dir/meta"

    local session="${meta[session]:-}" work_dir="${meta[work_dir]:-}" layout="${meta[layout]:-vertical}"
    local config_file="${meta[config]:-}" main_pane="${meta[main_pane]:-}"
    local origin="${meta[origin]:-}" mode="${meta[mode]:-}"

    if [[ -z "$session" ]]; then
        echo "Error: session not found in metadata" >&2; return 1
    fi
    if ! tmux has-session -t "$session" 2>/dev/null; then
        echo "Error: session '$session' not running" >&2; return 1
    fi

    CONFIG_FILE="$config_file"
    # Wire up per-project config from session's origin directory
    AE_LOCAL_CONFIG=""
    if [[ -n "$origin" ]] && [[ -f "${origin}/.ae/config" ]]; then
        AE_LOCAL_CONFIG="${origin}/.ae/config"
    fi
    local cmd
    cmd="$(get_config "agents.${alias_name}")"
    if [[ -z "$cmd" ]]; then
        echo "Error: agent '${alias_name}' not defined in $config_file" >&2; return 1
    fi

    # Split pane
    local pane_id
    if [[ "$layout" == "vertical" ]]; then
        pane_id="$(tmux split-window -h -t "$session" -c "$work_dir" -P -F '#{pane_id}')"
    else
        pane_id="$(tmux split-window -v -t "$session" -c "$work_dir" -P -F '#{pane_id}')"
    fi

    # Rebalance layout
    if [[ "$layout" == "vertical" ]]; then
        tmux select-layout -t "$session" even-horizontal
    else
        tmux select-layout -t "$session" even-vertical
    fi

    # Register spawned agent in meta (flock-protected to prevent races)
    local session_id tool_kind next_idx slot
    session_id="$(resolve_agent_session_id "$cmd" "spawned.0")"
    tool_kind="$(tool_kind_from_cmd "$cmd")"
    {
        flock -w 5 200 || { echo "Error: could not lock meta" >&2; return 1; }
        next_idx=0
        while grep -q "^agent\\.spawned\\.${next_idx}=" "$meta_dir/meta" 2>/dev/null; do
            next_idx=$(( next_idx + 1 ))
        done
        slot="spawned.${next_idx}"
        [[ -z "$spawn_name" ]] && spawn_name="helper-${next_idx}"
        session_id="$(resolve_agent_session_id "$cmd" "$slot")"
        echo "agent.${slot}=${alias_name}:${spawn_name}:${session_id}" >> "$meta_dir/meta"
    } 200>"$meta_dir/meta.lock"

    # Label pane (after flock so spawn_name is resolved)
    tmux select-pane -t "$pane_id" -T "ae:${alias_name}:${spawn_name}"
    tmux set-option -p -t "$pane_id" @ae_agent "${alias_name}:${spawn_name}"

    # Regenerate workspace.md from live panes
    regenerate_manifest "$session" "$work_dir" "$origin" "$mode" "$main_pane" "$meta_dir"

    # Wait for new pane's shell to initialize before sending commands
    sleep 0.3

    # Launch agent with session-scoped ID and ae workspace context
    local scoped_cmd initial_msg
    scoped_cmd="$(inject_session_id "$cmd" "$session_id")"
    scoped_cmd="$(inject_ae_context "$scoped_cmd" "$meta_dir" "$session" "$work_dir" "$slot")"
    # For agents without system prompt injection, combine workspace context + spawn prompt
    initial_msg="$(initial_prompt_for_cmd "$cmd" "$meta_dir" "$session" "$work_dir")"
    if [[ -n "$initial_msg" ]]; then
        initial_msg="${initial_msg} --- ${prompt}"
    fi
    send_agent_cmd "$pane_id" "$scoped_cmd" "$initial_msg"

    # Post-launch: capture codex session ID if needed
    if [[ "$tool_kind" == "codex" ]]; then
        capture_codex_session_id "$pane_id" "$slot" "$meta_dir" &
    fi

    # For agents with system prompt injection, send spawn prompt separately
    if [[ -z "$initial_msg" ]]; then
        sleep 1
        local buf="ae-spawn-$$"
        tmux select-pane -t "$pane_id"
        tmux set-buffer -b "$buf" -- "$prompt"
        tmux paste-buffer -d -b "$buf" -t "$pane_id"
        sleep 0.3
        tmux send-keys -t "$pane_id" C-m
    fi

    echo "Spawned ${alias_name}:${spawn_name} in pane $pane_id"
}

# Regenerate workspace.md from live tmux pane state
# Scans panes with ae: title prefix, builds agent table
regenerate_manifest() {
    local sess="$1" wdir="$2" origin="$3" mode="$4" main_pane="$5" sessions_dir="$6"
    local manifest="${sessions_dir}/workspace.md"

    # Describe copy mode
    local copy_desc
    case "$mode" in
        git)   copy_desc="You are working on a git worktree (detached HEAD from the origin). Push to remote and merge from there." ;;
        full)  copy_desc="You are working on a full copy of the project. Push to remote and merge from there." ;;
        local) copy_desc="You are working directly in the project directory (local mode). Changes affect the original files immediately." ;;
    esac

    # Build agent rows from live panes (using @ae_agent option, immune to title overrides)
    local agent_rows=""
    while IFS=$'\t' read -r pane_id ae_agent; do
        [[ -n "$ae_agent" ]] || continue
        local alias_name="${ae_agent%%:*}"
        local agent_name="${ae_agent#*:}"
        agent_name="${agent_name%%:*}"  # guard against nested colons
        local role="agent"
        [[ "$pane_id" == "$main_pane" ]] && role="lead"
        local cmd tool_label
        cmd="$(get_config "agents.${alias_name}")"
        tool_label="$(tool_name_from_cmd "${cmd:-$alias_name}")"
        agent_rows="${agent_rows}| ${alias_name}:${agent_name} | ${tool_label} | ${role} | ${pane_id} |
"
    done < <(tmux list-panes -t "$sess" -F '#{pane_id}	#{@ae_agent}' 2>/dev/null)

    # Collect available aliases from config for spawn section
    local available_aliases=""
    while IFS= read -r entry; do
        if [[ "$entry" == agents.* ]]; then
            local aname="${entry%%=*}"
            aname="${aname#agents.}"
            if [[ -n "$available_aliases" ]]; then
                available_aliases="${available_aliases}, ${aname}"
            else
                available_aliases="$aname"
            fi
        fi
    done < <(parse_config)

    cat > "$manifest" <<EOF
# ae workspace

Session: ${sess}
Origin: ${origin}
Directory: ${wdir}
Mode: ${mode}

${copy_desc}

## Agents

| Agent | Tool | Role | Pane |
|-------|------|------|------|
${agent_rows}
## Communication

Send a message to another agent by name:
\`\`\`bash
${sessions_dir}/send "<agent_name>" "your message"
\`\`\`

When another agent sends you a question or task, **reply back via send** when done:
\`\`\`bash
${sessions_dir}/send "<their_agent_name>" "your reply"
\`\`\`

Do not poll or capture panes to wait for replies — answers arrive as incoming messages.

## Peek

View recent output from another agent's pane:
\`\`\`bash
${sessions_dir}/peek <agent_name> [lines]
\`\`\`

Default: 80 lines. Max: 2000.

## Spawn

Add another agent to this workspace:
\`\`\`bash
${sessions_dir}/spawn <alias>:<name> [prompt]
\`\`\`

Always give spawned agents a descriptive role name (e.g. \`codex:reviewer\`, \`claude:pair-programmer\`).

Available aliases: ${available_aliases} (from ~/.ae/config)

## Rules

- Coordinate file edits -- don't modify the same file simultaneously
- The human can see all panes and may intervene at any time
- Always use the send helper above to communicate with other agents (never raw tmux send-keys)
EOF
}

# --- Agent launch helper (must be defined before dispatcher for _spawn) ---
send_agent_cmd() {
    local pane="$1" cmd="$2" prompt="$3"
    case "$cmd" in
        codex*resume*)
            # codex resume doesn't accept inline prompts — launch, then send prompt as input
            # Only send prompt if codex is still running (avoids shell execution on resume failure)
            # Fallback: if resume fails (stale UUID), start fresh — strip "resume <uuid>" but keep flags
            local codex_fallback
            codex_fallback="$(echo "$cmd" | sed 's/ *resume [^ ]*//')"
            tmux send-keys -t "$pane" "$cmd || $codex_fallback" C-m
            if [[ -n "$prompt" ]]; then
                (sleep 3 && \
                    if tmux list-panes -F '#{pane_id} #{pane_current_command}' | grep -q "^${pane} codex$"; then
                        local buf="ae-launch-$$-${pane}"
                        tmux select-pane -t "$pane"
                        tmux set-buffer -b "$buf" -- "$prompt"
                        tmux paste-buffer -d -b "$buf" -t "$pane"
                        sleep 0.3
                        tmux send-keys -t "$pane" C-m
                    fi
                ) &
            fi
            ;;
        opencode*)
            # OpenCode has no system prompt flag — launch TUI, then paste context as first message
            tmux send-keys -t "$pane" "$cmd" C-m
            if [[ -n "$prompt" ]]; then
                (sleep 3 && \
                    if tmux list-panes -F '#{pane_id} #{pane_current_command}' | grep -q "^${pane} opencode$"; then
                        local buf="ae-launch-$$-${pane}"
                        tmux select-pane -t "$pane"
                        tmux set-buffer -b "$buf" -- "$prompt"
                        tmux paste-buffer -d -b "$buf" -t "$pane"
                        sleep 0.3
                        tmux send-keys -t "$pane" C-m
                    fi
                ) &
            fi
            ;;
        *)
            local buf="ae-launch-$$-${pane}" launch_cmd="$cmd"
            # Ensure Claude Code doesn't detect nesting when ae is run from inside a Claude session
            if [[ "$cmd" == claude* ]]; then
                launch_cmd="env -u CLAUDECODE -u CLAUDE_CODE_SESSION ${launch_cmd}"
            fi
            # Resilient resume: if claude --resume UUID fails, fall back to --continue
            if [[ "$cmd" == claude*" --resume "* ]]; then
                local fallback
                fallback="$(echo "$cmd" | sed 's/--resume [^ ]*/--continue/')"
                launch_cmd="${cmd} || ${fallback}"
            fi
            if [[ -n "$prompt" ]]; then
                # Buffer-paste avoids tmux escaping issues; shell-escape single quotes in prompt
                local escaped_prompt="${prompt//\'/\'\\\'\'}"
                tmux set-buffer -b "$buf" -- "${launch_cmd} '${escaped_prompt}'"
            else
                tmux set-buffer -b "$buf" -- "$launch_cmd"
            fi
            tmux paste-buffer -d -b "$buf" -t "$pane"
            tmux send-keys -t "$pane" C-m
            ;;
    esac
}

# --- Dispatcher ---
case "${1:-}" in
    list|ls)        cmd_list; exit 0 ;;
    status)         cmd_status "${2:-}"; exit $? ;;
    stop)           cmd_stop "${2:-}"; exit $? ;;
    end|rm)              cmd_end "${2:-}" "${3:-}"; exit $? ;;
    _spawn)              _cmd_spawn "${@:2}"; exit $? ;;
    help|-h|--help) cmd_help; exit 0 ;;
esac

# --- Parse flags ---
COPY_MODE_OVERRIDE=""
SESSION=""
MAIN_OVERRIDE=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --worktree) COPY_MODE_OVERRIDE="git"; shift ;;
        --copy)     COPY_MODE_OVERRIDE="full"; shift ;;
        --local)    COPY_MODE_OVERRIDE="local"; shift ;;
        use)
            shift
            if [[ $# -eq 0 ]]; then
                echo "Error: 'use' requires an agent alias (e.g. ae myproject use codex)" >&2; exit 1
            fi
            MAIN_OVERRIDE="$1"; shift
            ;;
        --*)    echo "Error: unknown flag '$1'. Use --worktree, --copy, or --local." >&2; exit 1 ;;
        *)      SESSION="$1"; shift ;;
    esac
done

# Session name: use argument if given, otherwise derive from PWD
if [[ -z "$SESSION" ]]; then
    SESSION="$(default_session_name)"
fi

# Existing session? Just reattach (but only if it's an ae session).
if tmux has-session -t "$SESSION" 2>/dev/null; then
    if tmux show-environment -t "$SESSION" AE_SESSION 2>/dev/null | grep -q '^AE_SESSION='; then
        tmux_attach "$SESSION"
    else
        echo "Error: tmux session '$SESSION' exists but is not an ae session." >&2
        exit 1
    fi
fi

# --- Validate config before creating anything ---
# Parse alias[:name] — e.g. "claude:lead" → alias=claude, name=lead
# If no name given, name defaults to the alias itself
# On resume: recover agent from session meta (preserves 'use' override)
if [[ -z "$MAIN_OVERRIDE" ]]; then
    _saved_main="$(read_session_meta "$SESSION" agent.main)"
    if [[ -n "$_saved_main" ]]; then
        # agent.main format is alias:name:session_id — extract alias:name
        _saved_alias="${_saved_main%%:*}"
        _saved_rest="${_saved_main#*:}"
        _saved_name="${_saved_rest%%:*}"
        MAIN_RAW="${_saved_alias}:${_saved_name}"
    else
        MAIN_RAW="$(get_config workspace.main)"
    fi
else
    MAIN_RAW="$MAIN_OVERRIDE"
fi
if [[ "$MAIN_RAW" == *:* ]]; then
    MAIN_ALIAS="${MAIN_RAW%%:*}"
    MAIN_NAME="${MAIN_RAW#*:}"
else
    MAIN_ALIAS="$MAIN_RAW"
    MAIN_NAME="$MAIN_RAW"  # default name = alias
fi
if [[ "$MAIN_NAME" == *:* ]]; then
    echo "Error: agent name '${MAIN_NAME}' cannot contain ':' — use alias:name format (one colon)" >&2
    exit 1
fi
LAYOUT="$(get_config workspace.layout)"
WORKERS_RAW="$(get_config workspace.workers)"

# Determine copy mode: CLI flag > config > default (local)
if [[ -n "$COPY_MODE_OVERRIDE" ]]; then
    COPY_MODE="$COPY_MODE_OVERRIDE"
else
    COPY_MODE="$(get_config workspace.copy)"
    COPY_MODE="${COPY_MODE:-local}"
fi

if [[ "$COPY_MODE" != "git" ]] && [[ "$COPY_MODE" != "full" ]] && [[ "$COPY_MODE" != "local" ]]; then
    echo "Error: invalid copy mode '${COPY_MODE}'. Use 'git', 'full', or 'local'." >&2
    exit 1
fi

if [[ -z "$MAIN_ALIAS" ]]; then
    echo "Error: workspace.main not set in $CONFIG_FILE" >&2
    exit 1
fi

MAIN_CMD="$(get_config "agents.${MAIN_ALIAS}")"
if [[ -z "$MAIN_CMD" ]]; then
    echo "Error: agent '${MAIN_ALIAS}' not defined in $CONFIG_FILE" >&2
    exit 1
fi

WORKER_CMDS=()
WORKER_ALIASES=()
WORKER_NAMES=()
if [[ -n "$WORKERS_RAW" ]]; then
    IFS=',' read -ra _entries <<< "$WORKERS_RAW"
    for entry in "${_entries[@]}"; do
        entry="$(echo "$entry" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        if [[ "$entry" == *:* ]]; then
            walias="${entry%%:*}"
            wname="${entry#*:}"
            if [[ "$wname" == *:* ]]; then
                echo "Error: worker name '${wname}' cannot contain ':' — use alias:name format (one colon)" >&2
                exit 1
            fi
        else
            walias="$entry"
            wname="$entry"  # default name = alias
        fi
        cmd="$(get_config "agents.${walias}")"
        if [[ -z "$cmd" ]]; then
            echo "Error: agent '${walias}' not defined in $CONFIG_FILE" >&2
            exit 1
        fi
        WORKER_ALIASES+=("$walias")
        WORKER_NAMES+=("$wname")
        WORKER_CMDS+=("$cmd")
    done
    # Deduplicate names: append index if a name collides with main or another worker
    declare -A _name_seen=()
    _name_seen["$MAIN_NAME"]=1
    for i in "${!WORKER_NAMES[@]}"; do
        wn="${WORKER_NAMES[$i]}"
        if [[ -n "${_name_seen[$wn]:-}" ]]; then
            WORKER_NAMES[$i]="${wn}-${i}"
        fi
        _name_seen["${WORKER_NAMES[$i]}"]=1
    done
    unset _name_seen
fi

# --- Working directory: local, resume existing, or create new ---
ORIGIN_DIR="$PWD"
WORK_DIR="${WORKTREES_DIR}/${SESSION}"
RESUMING=false

if [[ "$COPY_MODE" == "local" ]]; then
    # Local mode: work directly in current directory, no copy
    # Mode collision: error if a stopped worktree/copy session exists with the same name
    if [[ -d "${WORKTREES_DIR}/${SESSION}" ]]; then
        echo "Error: stopped session '${SESSION}' exists as worktree/copy. End it first (ae end ${SESSION}), or use a different name." >&2
        exit 1
    fi
    WORK_DIR="$PWD"
    # Resume if session meta exists from a previous run (e.g. after reboot)
    if [[ -f "${SESSIONS_DIR}/${SESSION}/meta" ]]; then
        RESUMING=true
        echo "Resuming session ${SESSION}..."
    fi
elif [[ -d "$WORK_DIR" ]]; then
    # Existing worktree — resume it (e.g. after reboot)
    RESUMING=true
    echo "Resuming session ${SESSION}..."
else
    mkdir -p "$WORK_DIR"
    if [[ "$COPY_MODE" == "git" ]]; then
        # Git worktree: fast, shares .git, true isolation
        if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            echo "Creating git worktree..."
            git worktree add --detach "$WORK_DIR" HEAD 2>/dev/null || {
                # Stale registration — prune and retry
                git worktree prune 2>/dev/null || true
                git worktree add --detach "$WORK_DIR" HEAD
            }
        else
            echo "Warning: not a git repo, falling back to full copy." >&2
            COPY_MODE="full"
            echo "Creating full copy..."
            cp -a "$PWD/." "$WORK_DIR"
        fi
    else
        # Full copy: includes untracked files (node_modules, .venv, etc.)
        echo "Creating full copy..."
        cp -a "$PWD/." "$WORK_DIR"
    fi
    echo "Working copy ready."
fi

# --- Create tmux session in the worktree ---
PANE_IDS=()
tmux new-session -d -s "$SESSION" -c "$WORK_DIR"
# Unset env vars that prevent Claude Code from starting inside tmux
tmux set-environment -t "$SESSION" -u CLAUDECODE
tmux set-environment -t "$SESSION" -u CLAUDE_CODE_SESSION

# Tag as ae session and store directories/mode
tmux set-environment -t "$SESSION" AE_SESSION 1
tmux set-environment -t "$SESSION" AE_ORIGIN "$ORIGIN_DIR"
tmux set-environment -t "$SESSION" AE_DIR "$WORK_DIR"
tmux set-environment -t "$SESSION" AE_MODE "$COPY_MODE"

# ae-specific tmux options (session-scoped, doesn't affect other tmux usage)
tmux set-option -t "$SESSION" mouse on
tmux set-option -t "$SESSION" focus-events on 2>/dev/null || true
tmux set-option -t "$SESSION" history-limit 50000
tmux set-option -t "$SESSION" pane-border-status top
tmux set-option -t "$SESSION" pane-border-format " #{@ae_agent} "
tmux set-option -t "$SESSION" status-left "[ae] "
tmux set-option -t "$SESSION" automatic-rename off
tmux rename-window -t "$SESSION" "$SESSION"

PANE_IDS+=("$(tmux display-message -t "$SESSION" -p '#{pane_id}')")

for i in "${!WORKER_CMDS[@]}"; do
    local_id=""
    if [[ "$LAYOUT" == "vertical" ]]; then
        local_id="$(tmux split-window -h -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
    else
        local_id="$(tmux split-window -v -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
    fi
    PANE_IDS+=("$local_id")
done

# Distribute panes evenly
if (( ${#PANE_IDS[@]} > 1 )); then
    if [[ "$LAYOUT" == "vertical" ]]; then
        tmux select-layout -t "$SESSION" even-horizontal
    else
        tmux select-layout -t "$SESSION" even-vertical
    fi
fi

# Label panes: title for border display, @ae_agent option for reliable identity
tmux select-pane -t "${PANE_IDS[0]}" -T "ae:${MAIN_ALIAS}:${MAIN_NAME}"
tmux set-option -p -t "${PANE_IDS[0]}" @ae_agent "${MAIN_ALIAS}:${MAIN_NAME}"
for i in "${!WORKER_ALIASES[@]}"; do
    idx=$(( i + 1 ))
    tmux select-pane -t "${PANE_IDS[$idx]}" -T "ae:${WORKER_ALIASES[$i]}:${WORKER_NAMES[$i]}"
    tmux set-option -p -t "${PANE_IDS[$idx]}" @ae_agent "${WORKER_ALIASES[$i]}:${WORKER_NAMES[$i]}"
done

# --- Generate helper scripts and workspace manifest ---
AE_META="${SESSIONS_DIR}/${SESSION}"
mkdir -p -m 0700 "$AE_META"

# Session metadata (used by ae list/end for stopped sessions, and by spawn helper)
# Always write full meta: on resume, preserve original mode/origin from existing file
META_MODE="$COPY_MODE"
META_ORIGIN="$ORIGIN_DIR"
if [[ "$RESUMING" == true ]]; then
    # read_session_meta checks new path then falls back to legacy path
    META_MODE="$(read_session_meta "$SESSION" mode)"
    META_ORIGIN="$(read_session_meta "$SESSION" origin)"
    META_MODE="${META_MODE:-$COPY_MODE}"
    META_ORIGIN="${META_ORIGIN:-$ORIGIN_DIR}"
fi

MAIN_TOOL_KIND="$(tool_kind_from_cmd "$MAIN_CMD")"
MAIN_SESSION_ID="$(resolve_agent_session_id "$MAIN_CMD" "main")"

declare -a WORKER_SESSION_IDS=()
for i in "${!WORKER_CMDS[@]}"; do
    WORKER_SESSION_IDS+=("$(resolve_agent_session_id "${WORKER_CMDS[$i]}" "worker.${i}")")
done

# Load spawned agents from previous session (resume only)
declare -a SPAWNED_ALIASES=() SPAWNED_NAMES=() SPAWNED_CMDS=() SPAWNED_SESSION_IDS=()
if [[ "$RESUMING" == true ]]; then
    sidx=0
    while true; do
        sentry="$(read_session_meta "$SESSION" "agent.spawned.${sidx}")"
        [[ -z "$sentry" ]] && break
        # Format: alias:name:session_id
        salias="${sentry%%:*}"
        _rest="${sentry#*:}"
        sname="${_rest%%:*}"
        scmd="$(get_config "agents.${salias}")"
        if [[ -n "$scmd" ]]; then
            SPAWNED_ALIASES+=("$salias")
            SPAWNED_NAMES+=("$sname")
            SPAWNED_CMDS+=("$scmd")
            SPAWNED_SESSION_IDS+=("$(resolve_agent_session_id "$scmd" "spawned.${sidx}")")
        fi
        sidx=$(( sidx + 1 ))
    done

    # Create panes for spawned agents
    for i in "${!SPAWNED_ALIASES[@]}"; do
        local_id=""
        if [[ "$LAYOUT" == "vertical" ]]; then
            local_id="$(tmux split-window -h -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
        else
            local_id="$(tmux split-window -v -t "$SESSION" -c "$WORK_DIR" -P -F '#{pane_id}')"
        fi
        PANE_IDS+=("$local_id")
        tmux select-pane -t "$local_id" -T "ae:${SPAWNED_ALIASES[$i]}:${SPAWNED_NAMES[$i]}"
        tmux set-option -p -t "$local_id" @ae_agent "${SPAWNED_ALIASES[$i]}:${SPAWNED_NAMES[$i]}"
    done
    # Rebalance if spawned agents were added
    if (( ${#SPAWNED_ALIASES[@]} > 0 )); then
        if [[ "$LAYOUT" == "vertical" ]]; then
            tmux select-layout -t "$SESSION" even-horizontal
        else
            tmux select-layout -t "$SESSION" even-vertical
        fi
    fi
fi

AE_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

cat > "${AE_META}/meta" <<EOF
mode=${META_MODE}
origin=${META_ORIGIN}
session=${SESSION}
work_dir=${WORK_DIR}
layout=${LAYOUT:-vertical}
config=${CONFIG_FILE}
main_pane=${PANE_IDS[0]}
ae_path=${AE_PATH}
agent.main=${MAIN_ALIAS}:${MAIN_NAME}:${MAIN_SESSION_ID}
EOF
for i in "${!WORKER_CMDS[@]}"; do
    echo "agent.worker.${i}=${WORKER_ALIASES[$i]}:${WORKER_NAMES[$i]}:${WORKER_SESSION_IDS[$i]}" >> "${AE_META}/meta"
done
for i in "${!SPAWNED_ALIASES[@]}"; do
    echo "agent.spawned.${i}=${SPAWNED_ALIASES[$i]}:${SPAWNED_NAMES[$i]}:${SPAWNED_SESSION_IDS[$i]}" >> "${AE_META}/meta"
done

# Helper: send <target> <message> — focuses pane, pastes text, submits
cat > "${AE_META}/send" <<'SENDEOF'
#!/usr/bin/env bash
if [[ $# -lt 2 ]]; then
    echo "Usage: send <agent-name|pane-id> <message>" >&2
    echo "  Examples: send claude:lead \"hello\"" >&2
    echo "           send %0 \"hello\"" >&2
    exit 1
fi
target="$1"; shift
msg="$*"
buf="ae-send-$$"

# Resolve agent name to pane ID (names like claude:main, codex:worker-0)
if [[ "$target" != %* ]]; then
    META_DIR="$(cd "$(dirname "$0")" && pwd)"
    session="$(grep '^session=' "$META_DIR/meta" | cut -d= -f2-)"
    resolved=""
    bare_match=""
    bare_count=0
    while IFS=$'\t' read -r pid aagent; do
        # Exact match on alias:name
        if [[ "$aagent" == "${target}" ]]; then
            resolved="$pid"
            break
        fi
        # Bare name match (e.g. "lead" matches "claude:lead")
        aname="${aagent#*:}"
        if [[ "$aname" == "${target}" ]]; then
            bare_match="$pid"
            bare_count=$((bare_count + 1))
        fi
    done < <(tmux list-panes -t "$session" -F '#{pane_id}	#{@ae_agent}' 2>/dev/null)
    # Fall back to bare name if unambiguous
    if [[ -z "$resolved" && "$bare_count" -eq 1 ]]; then
        resolved="$bare_match"
    fi
    if [[ -z "$resolved" ]]; then
        if [[ "$bare_count" -gt 1 ]]; then
            echo "Error: ambiguous name '${target}' — use alias:name format" >&2
        else
            echo "Error: agent '${target}' not found" >&2
        fi
        exit 1
    fi
    target="$resolved"
fi

# Save current pane so we can restore focus after send
current="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
restore_focus() { [[ -n "$current" ]] && tmux select-pane -t "$current" 2>/dev/null; }
trap restore_focus EXIT

# Focus the target pane (TUIs only process input when focused)
tmux select-pane -t "$target"

# Cancel copy-mode if active
tmux send-keys -t "$target" -X cancel 2>/dev/null || true

# Paste via named buffer (avoids races with concurrent sends)
tmux set-buffer -b "$buf" -- "$msg"
tmux paste-buffer -d -b "$buf" -t "$target"

# Brief delay so the TUI can process the pasted text before Enter
sleep 0.3
tmux send-keys -t "$target" C-m

# Let the TUI process the submission before focus restores
sleep 0.3
SENDEOF
chmod 0700 "${AE_META}/send"

# Helper: peek <target> [lines] — capture recent output from another agent's pane
cat > "${AE_META}/peek" <<'PEEKEOF'
#!/usr/bin/env bash
if [[ $# -lt 1 ]]; then
    echo "Usage: peek <agent-name|pane-id> [lines]" >&2
    echo "  Examples: peek codex:reviewer" >&2
    echo "           peek codex:reviewer 50" >&2
    echo "           peek %3 200" >&2
    exit 1
fi
target="$1"
lines="${2:-80}"

# Validate lines is numeric and clamp
if ! [[ "$lines" =~ ^[0-9]+$ ]]; then
    echo "Error: lines must be a number, got '$lines'" >&2
    exit 1
fi
(( lines > 2000 )) && lines=2000
(( lines < 1 )) && lines=1

# Resolve agent name to pane ID (same logic as send)
if [[ "$target" != %* ]]; then
    META_DIR="$(cd "$(dirname "$0")" && pwd)"
    session="$(grep '^session=' "$META_DIR/meta" | cut -d= -f2-)"
    resolved=""
    bare_match=""
    bare_count=0
    while IFS=$'\t' read -r pid aagent; do
        if [[ "$aagent" == "${target}" ]]; then
            resolved="$pid"
            break
        fi
        aname="${aagent#*:}"
        if [[ "$aname" == "${target}" ]]; then
            bare_match="$pid"
            bare_count=$((bare_count + 1))
        fi
    done < <(tmux list-panes -t "$session" -F '#{pane_id}	#{@ae_agent}' 2>/dev/null)
    if [[ -z "$resolved" && "$bare_count" -eq 1 ]]; then
        resolved="$bare_match"
    fi
    if [[ -z "$resolved" ]]; then
        if [[ "$bare_count" -gt 1 ]]; then
            echo "Error: ambiguous name '${target}' — use alias:name format" >&2
        else
            echo "Error: agent '${target}' not found" >&2
        fi
        exit 1
    fi
    target="$resolved"
fi

tmux capture-pane -p -J -S "-${lines}" -E - -t "$target"
PEEKEOF
chmod 0700 "${AE_META}/peek"

# Helper: spawn <alias> [prompt] — thin wrapper that calls ae _spawn
cat > "${AE_META}/spawn" <<'SPAWNEOF'
#!/usr/bin/env bash
set -euo pipefail
META_DIR="$(cd "$(dirname "$0")" && pwd)"
AE_PATH="$(grep '^ae_path=' "$META_DIR/meta" | cut -d= -f2-)"
if [[ ! -x "$AE_PATH" ]]; then
    AE_PATH="$(command -v ae 2>/dev/null || true)"
fi
if [[ -z "${AE_PATH:-}" ]] || [[ ! -x "$AE_PATH" ]]; then
    echo "Error: ae not found (expected at $(grep '^ae_path=' "$META_DIR/meta" | cut -d= -f2-))" >&2
    exit 1
fi
if [[ $# -lt 1 ]]; then
    echo "Usage: spawn <alias>[:<name>] [prompt]" >&2
    exit 1
fi
exec "$AE_PATH" _spawn "$META_DIR" "$@"
SPAWNEOF
chmod 0700 "${AE_META}/spawn"

# Helper: register-sid — codex agents run this to self-register their session ID
cat > "${AE_META}/register-sid" <<'REGSIDEOF'
#!/usr/bin/env bash
# Find the most recent codex session file and write its UUID to codex.<slot>.sid
META_DIR="$(cd "$(dirname "$0")" && pwd)"
SLOT="${1:-default}"
sid=$(ls -t ~/.codex/sessions/$(date -u +%Y/%m/%d)/*.jsonl 2>/dev/null | head -1 | grep -oP '[0-9a-f]{8}(-[0-9a-f]{4}){3}-[0-9a-f]{12}')
if [ -n "$sid" ]; then
    echo "$sid" > "$META_DIR/codex.${SLOT}.sid"
    echo "registered session $sid for slot $SLOT"
else
    echo "no codex session found for today" >&2
    exit 1
fi
REGSIDEOF
chmod 0700 "${AE_META}/register-sid"

# Generate initial workspace.md from live pane state
regenerate_manifest "$SESSION" "$WORK_DIR" "$ORIGIN_DIR" "$COPY_MODE" "${PANE_IDS[0]}" "$AE_META"

# --- Launch agents ---

if [[ "$RESUMING" == true ]]; then
    # Resume: use session-scoped resume commands (exact conversation, not CWD heuristic)
    MAIN_RESUME="$(resume_cmd_from_cmd "$MAIN_CMD" "$MAIN_SESSION_ID")"
    MAIN_RESUME="$(inject_ae_context "$MAIN_RESUME" "$AE_META" "$SESSION" "$WORK_DIR" "main")"
    send_agent_cmd "${PANE_IDS[0]}" "$MAIN_RESUME" "$(initial_prompt_for_cmd "$MAIN_CMD" "$AE_META" "$SESSION" "$WORK_DIR")"
    for i in "${!WORKER_CMDS[@]}"; do
        idx=$(( i + 1 ))
        WORKER_RESUME="$(resume_cmd_from_cmd "${WORKER_CMDS[$i]}" "${WORKER_SESSION_IDS[$i]:-}")"
        WORKER_RESUME="$(inject_ae_context "$WORKER_RESUME" "$AE_META" "$SESSION" "$WORK_DIR" "worker.${i}")"
        send_agent_cmd "${PANE_IDS[$idx]}" "$WORKER_RESUME" "$(initial_prompt_for_cmd "${WORKER_CMDS[$i]}" "$AE_META" "$SESSION" "$WORK_DIR")"
    done
    # Resume spawned agents
    for i in "${!SPAWNED_CMDS[@]}"; do
        sidx=$(( ${#WORKER_CMDS[@]} + i + 1 ))
        SPAWNED_RESUME="$(resume_cmd_from_cmd "${SPAWNED_CMDS[$i]}" "${SPAWNED_SESSION_IDS[$i]:-}")"
        SPAWNED_RESUME="$(inject_ae_context "$SPAWNED_RESUME" "$AE_META" "$SESSION" "$WORK_DIR" "spawned.${i}")"
        send_agent_cmd "${PANE_IDS[$sidx]}" "$SPAWNED_RESUME" "$(initial_prompt_for_cmd "${SPAWNED_CMDS[$i]}" "$AE_META" "$SESSION" "$WORK_DIR")"
    done
else
    # Fresh start with session-scoped IDs (enables targeted resume later)
    SCOPED_MAIN="$(inject_session_id "$MAIN_CMD" "$MAIN_SESSION_ID")"
    SCOPED_MAIN="$(inject_ae_context "$SCOPED_MAIN" "$AE_META" "$SESSION" "$WORK_DIR" "main")"
    send_agent_cmd "${PANE_IDS[0]}" "$SCOPED_MAIN" "$(initial_prompt_for_cmd "$MAIN_CMD" "$AE_META" "$SESSION" "$WORK_DIR")"
    for i in "${!WORKER_CMDS[@]}"; do
        idx=$(( i + 1 ))
        SCOPED_WORKER="$(inject_session_id "${WORKER_CMDS[$i]}" "${WORKER_SESSION_IDS[$i]:-}")"
        SCOPED_WORKER="$(inject_ae_context "$SCOPED_WORKER" "$AE_META" "$SESSION" "$WORK_DIR" "worker.${i}")"
        send_agent_cmd "${PANE_IDS[$idx]}" "$SCOPED_WORKER" "$(initial_prompt_for_cmd "${WORKER_CMDS[$i]}" "$AE_META" "$SESSION" "$WORK_DIR")"
    done
fi

# Capture Codex session IDs in background (runs after launch, doesn't delay attach)
if [[ "$RESUMING" != true ]]; then
    if [[ "$(tool_kind_from_cmd "$MAIN_CMD")" == "codex" ]]; then
        capture_codex_session_id "${PANE_IDS[0]}" "main" "$AE_META" &
    fi
    for i in "${!WORKER_CMDS[@]}"; do
        if [[ "$(tool_kind_from_cmd "${WORKER_CMDS[$i]}")" == "codex" ]]; then
            capture_codex_session_id "${PANE_IDS[$(( i + 1 ))]}" "worker.${i}" "$AE_META" &
        fi
    done
fi

# Focus main pane and attach
tmux select-pane -t "${PANE_IDS[0]}"
tmux_attach "$SESSION"
