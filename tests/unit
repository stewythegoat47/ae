#!/usr/bin/env bash
# Test suite for ae pure functions
# Run: ./test (or: bash test)
# No dependencies beyond bash.

set -euo pipefail

PASS=0
FAIL=0
ERRORS=()

assert_eq() {
    local label="$1" expected="$2" actual="$3"
    if [[ "$expected" == "$actual" ]]; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        ERRORS+=("FAIL: $label\n  expected: \"$expected\"\n  actual:   \"$actual\"")
    fi
}

# Isolate config from user's real ~/.ae/config
CONFIG_FILE="/dev/null"
AE_LOCAL_CONFIG=""

# Extract pure function definitions from ae (matches "func() {" but not "func() ${BODY}" heredoc copies)
eval "$(awk '
    /^(parse_config|get_config|build_ae_context|strip_session_flags|strip_gemini_prompt_flags|resume_cmd_from_cmd|inject_session_id|inject_ae_context|initial_prompt_for_cmd|gen_uuid|tool_kind_from_cmd|tool_name_from_cmd|default_session_name|sanitize_branch_name)\(\) \{/ { printing=1 }
    printing { print }
    printing && /^\}$/ { printing=0 }
' "$(dirname "$0")/../ae")"

# ── strip_session_flags ──────────────────────────────────────────────

assert_eq "strip: --session-id with =" \
    "claude --model opus" \
    "$(strip_session_flags "claude --session-id=abc-123 --model opus")"

assert_eq "strip: --session-id with space" \
    "claude --model opus" \
    "$(strip_session_flags "claude --session-id abc-123 --model opus")"

assert_eq "strip: --resume with =" \
    "claude --model opus" \
    "$(strip_session_flags "claude --resume=abc-123 --model opus")"

assert_eq "strip: --resume with space" \
    "claude --model opus" \
    "$(strip_session_flags "claude --resume abc-123 --model opus")"

assert_eq "strip: --continue alone" \
    "claude --model opus" \
    "$(strip_session_flags "claude --continue --model opus")"

assert_eq "strip: --continue at end" \
    "claude --model opus" \
    "$(strip_session_flags "claude --model opus --continue")"

assert_eq "strip: preserves --continue-on-error" \
    "claude --continue-on-error --model opus" \
    "$(strip_session_flags "claude --continue-on-error --model opus")"

assert_eq "strip: preserves --continuation" \
    "sometool --continuation" \
    "$(strip_session_flags "sometool --continuation")"

assert_eq "strip: multiple flags at once" \
    "claude --model opus" \
    "$(strip_session_flags "claude --session-id abc --resume def --continue --model opus")"

assert_eq "strip: no flags to strip" \
    "codex --yolo -m gpt-5" \
    "$(strip_session_flags "codex --yolo -m gpt-5")"

assert_eq "strip: only --continue" \
    "claude" \
    "$(strip_session_flags "claude --continue")"

# ── tool_kind_from_cmd ───────────────────────────────────────────────

assert_eq "kind: claude" "claude" "$(tool_kind_from_cmd "claude --model opus")"
assert_eq "kind: codex"  "codex"  "$(tool_kind_from_cmd "codex --yolo")"
assert_eq "kind: opencode" "opencode" "$(tool_kind_from_cmd "opencode")"
assert_eq "kind: unknown" "unknown" "$(tool_kind_from_cmd "sometool --flag")"

# ── tool_name_from_cmd ──────────────────────────────────────────────

assert_eq "name: claude" "claude code" "$(tool_name_from_cmd "claude --model opus")"
assert_eq "name: codex"  "codex"       "$(tool_name_from_cmd "codex --yolo")"
assert_eq "name: opencode" "opencode"  "$(tool_name_from_cmd "opencode")"
assert_eq "name: unknown passes through" "mytool --flag" "$(tool_name_from_cmd "mytool --flag")"

# ── inject_session_id ───────────────────────────────────────────────

assert_eq "inject: claude gets --session-id" \
    "claude --model opus --session-id abc-123" \
    "$(inject_session_id "claude --model opus" "abc-123")"

assert_eq "inject: codex unchanged (no --session-id support)" \
    "codex --yolo" \
    "$(inject_session_id "codex --yolo" "abc-123")"

assert_eq "inject: pending treated as empty" \
    "claude --model opus" \
    "$(inject_session_id "claude --model opus" "pending")"

assert_eq "inject: empty session_id returns clean cmd" \
    "claude --model opus" \
    "$(inject_session_id "claude --model opus" "")"

assert_eq "inject: strips existing before injecting" \
    "claude --model opus --session-id new-uuid" \
    "$(inject_session_id "claude --session-id old-uuid --model opus" "new-uuid")"

# ── resume_cmd_from_cmd ─────────────────────────────────────────────

assert_eq "resume: claude with session_id → --resume" \
    "claude --model opus --resume abc-123" \
    "$(resume_cmd_from_cmd "claude --model opus" "abc-123")"

assert_eq "resume: claude without session_id → --continue" \
    "claude --model opus --continue" \
    "$(resume_cmd_from_cmd "claude --model opus")"

assert_eq "resume: claude with pending → --continue (fallback)" \
    "claude --model opus --continue" \
    "$(resume_cmd_from_cmd "claude --model opus" "pending")"

assert_eq "resume: codex with session_id preserves flags" \
    "codex --yolo resume abc-123" \
    "$(resume_cmd_from_cmd "codex --yolo" "abc-123")"

assert_eq "resume: codex without flags → plain resume" \
    "codex resume abc-123" \
    "$(resume_cmd_from_cmd "codex" "abc-123")"

assert_eq "resume: codex without session_id → fresh start" \
    "codex --yolo" \
    "$(resume_cmd_from_cmd "codex --yolo")"

assert_eq "resume: codex with pending → fresh start" \
    "codex --yolo" \
    "$(resume_cmd_from_cmd "codex --yolo" "pending")"

assert_eq "resume: gemini → --resume latest" \
    "gemini --yolo --resume latest" \
    "$(resume_cmd_from_cmd "gemini --yolo")"

assert_eq "resume: gemini strips old -i flag with quoted value" \
    "gemini --yolo --resume latest" \
    "$(resume_cmd_from_cmd "gemini --yolo -i 'old context with spaces'")"

assert_eq "resume: gemini strips --prompt-interactive" \
    "gemini --yolo --resume latest" \
    "$(resume_cmd_from_cmd "gemini --yolo --prompt-interactive 'old context'")"

assert_eq "strip: -i not stripped from non-gemini commands" \
    "codex --yolo -i input.txt" \
    "$(strip_session_flags "codex --yolo -i input.txt")"

assert_eq "resume: unknown agent → fresh start (clean cmd)" \
    "opencode" \
    "$(resume_cmd_from_cmd "opencode")"

assert_eq "resume: strips old flags before building resume cmd" \
    "claude --model opus --resume new-uuid" \
    "$(resume_cmd_from_cmd "claude --resume old-uuid --model opus" "new-uuid")"

# ── inject_ae_context ────────────────────────────────────────────────

result="$(inject_ae_context "claude --model opus" "/tmp/ae-test" "my-session" "/home/user/project")"
assert_eq "ae_context: claude gets --append-system-prompt" \
    "1" \
    "$([[ "$result" == *"--append-system-prompt"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: contains meta dir" \
    "1" \
    "$([[ "$result" == *"/tmp/ae-test/workspace.md"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: contains helpers path" \
    "1" \
    "$([[ "$result" == *"helpers in /tmp/ae-test/"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: contains spawn helper" \
    "1" \
    "$([[ "$result" == *"spawn <alias"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: contains ask helper" \
    "1" \
    "$([[ "$result" == *"ask <agent>"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: contains peek helper" \
    "1" \
    "$([[ "$result" == *"peek <agent>"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: contains session name" \
    "1" \
    "$([[ "$result" == *"my-session"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: contains work dir" \
    "1" \
    "$([[ "$result" == *"/home/user/project"* ]] && echo 1 || echo 0)"

result_codex="$(inject_ae_context "codex --yolo" "/tmp/ae-test" "my-session" "/home/user/project")"
assert_eq "ae_context: codex gets developer_instructions" \
    "1" \
    "$([[ "$result_codex" == *"developer_instructions="* ]] && echo 1 || echo 0)"

assert_eq "ae_context: codex contains meta dir" \
    "1" \
    "$([[ "$result_codex" == *"/tmp/ae-test/workspace.md"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: codex contains register-sid instruction" \
    "1" \
    "$([[ "$result_codex" == *"register-sid"* ]] && echo 1 || echo 0)"

# Codex with slot arg
result_codex_slot="$(inject_ae_context "codex --yolo" "/tmp/ae-test" "my-session" "/home/user/project" "worker.0")"
assert_eq "ae_context: codex slot passed to register-sid" \
    "1" \
    "$([[ "$result_codex_slot" == *"register-sid worker.0"* ]] && echo 1 || echo 0)"

result_gemini="$(inject_ae_context "gemini --yolo" "/tmp/ae-test" "my-session" "/home/user/project")"
assert_eq "ae_context: gemini gets -i flag" \
    "1" \
    "$([[ "$result_gemini" == *" -i '"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: gemini contains workspace context" \
    "1" \
    "$([[ "$result_gemini" == *"ae multi-agent workspace"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: unknown agent is passthrough" \
    "opencode" \
    "$(inject_ae_context "opencode" "/tmp/ae-test")"

# inject_ae_context with [prompt] instructions
_test_config="$(mktemp)"
printf '[prompt]\ninstructions = "Use Rust. No unsafe."\n' > "$_test_config"
CONFIG_FILE="$_test_config"
result_instr="$(inject_ae_context "claude --model opus" "/tmp/ae-test" "sess" "/home/user")"
CONFIG_FILE="/dev/null"
rm -f "$_test_config"

assert_eq "ae_context: includes user instructions" \
    "1" \
    "$([[ "$result_instr" == *"Use Rust. No unsafe."* ]] && echo 1 || echo 0)"

assert_eq "ae_context: instructions have separator" \
    "1" \
    "$([[ "$result_instr" == *"--- Workspace instructions:"* ]] && echo 1 || echo 0)"

# inject_ae_context: local config overrides global instructions
_global_cfg="$(mktemp)"
_local_cfg="$(mktemp)"
printf '[prompt]\ninstructions = "global rules"\n' > "$_global_cfg"
printf '[prompt]\ninstructions = "local rules"\n' > "$_local_cfg"
CONFIG_FILE="$_global_cfg"
AE_LOCAL_CONFIG="$_local_cfg"
result_override="$(inject_ae_context "claude --model opus" "/tmp/ae-test" "sess" "/home/user")"
CONFIG_FILE="/dev/null"
AE_LOCAL_CONFIG=""
rm -f "$_global_cfg" "$_local_cfg"

assert_eq "ae_context: local instructions override global" \
    "1" \
    "$([[ "$result_override" == *"local rules"* ]] && echo 1 || echo 0)"

assert_eq "ae_context: global instructions shadowed by local" \
    "0" \
    "$([[ "$result_override" == *"global rules"* ]] && echo 1 || echo 0)"

# initial_prompt_for_cmd: empty for claude/codex, context for others
assert_eq "initial_prompt: empty for claude" \
    "" \
    "$(initial_prompt_for_cmd "claude --model opus" "/tmp/ae" "sess" "/home/user")"

assert_eq "initial_prompt: Go for codex" \
    "Go" \
    "$(initial_prompt_for_cmd "codex --yolo" "/tmp/ae" "sess" "/home/user")"

assert_eq "initial_prompt: empty for gemini" \
    "" \
    "$(initial_prompt_for_cmd "gemini --yolo" "/tmp/ae" "sess" "/home/user")"

result_opencode="$(initial_prompt_for_cmd "opencode" "/tmp/ae" "sess" "/home/user")"
assert_eq "initial_prompt: opencode gets context" \
    "1" \
    "$([[ "$result_opencode" == *"ae multi-agent workspace"* ]] && echo 1 || echo 0)"

assert_eq "initial_prompt: opencode gets helpers path" \
    "1" \
    "$([[ "$result_opencode" == *"helpers in /tmp/ae/"* ]] && echo 1 || echo 0)"

# ── gen_uuid ─────────────────────────────────────────────────────────

uuid="$(gen_uuid)"
assert_eq "gen_uuid: produces valid UUID format" \
    "1" \
    "$([[ "$uuid" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]] && echo 1 || echo 0)"

uuid2="$(gen_uuid)"
assert_eq "gen_uuid: produces unique values" \
    "1" \
    "$([[ "$uuid" != "$uuid2" ]] && echo 1 || echo 0)"

# ── sanitize_branch_name ─────────────────────────────────────────────

assert_eq "branch: simple name" \
    "ae/myfeature" \
    "$(sanitize_branch_name "myfeature")"

assert_eq "branch: strips ae- prefix" \
    "ae/myfeature" \
    "$(sanitize_branch_name "ae-myfeature")"

assert_eq "branch: replaces spaces and special chars" \
    "ae/my-feature-v2" \
    "$(sanitize_branch_name "my feature!v2")"

assert_eq "branch: collapses repeated dashes" \
    "ae/a-b" \
    "$(sanitize_branch_name "a---b")"

assert_eq "branch: trims leading/trailing dashes" \
    "ae/foo" \
    "$(sanitize_branch_name "-foo-")"

assert_eq "branch: dots and underscores preserved" \
    "ae/v1.2_rc" \
    "$(sanitize_branch_name "v1.2_rc")"

# ── default_session_name ────────────────────────────────────────────

name="$(default_session_name)"
assert_eq "default_session_name: starts with ae-" \
    "1" \
    "$([[ "$name" == ae-* ]] && echo 1 || echo 0)"

assert_eq "default_session_name: contains hash suffix" \
    "1" \
    "$([[ "$name" =~ -[0-9a-f]{6}$ ]] && echo 1 || echo 0)"

assert_eq "default_session_name: deterministic (same PWD = same name)" \
    "$name" \
    "$(default_session_name)"

# ── Results ──────────────────────────────────────────────────────────

echo ""
if [[ ${#ERRORS[@]} -gt 0 ]]; then
    for err in "${ERRORS[@]}"; do
        echo -e "$err"
        echo ""
    done
fi
echo "${PASS} passed, ${FAIL} failed"
[[ $FAIL -eq 0 ]] && exit 0 || exit 1
